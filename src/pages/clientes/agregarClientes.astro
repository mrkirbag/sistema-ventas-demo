---
import Layout from '../../layouts/Layout.astro';
import { verificarToken } from '../../utils/auth.js';

const usuario = verificarToken(Astro.request);
if (!usuario) {
    return Astro.redirect('/login');
}
---

<Layout>
    <header class="page-header">
        <p class="eyebrow">Gestión comercial</p>
        <h1>Agregar cliente</h1>
        <p class="page-intro">Registra un nuevo cliente con su nombre, teléfono y cédula.</p>
    </header>

    <div class="btn-add_container">
        <a class="btn-add" href="/clientes">Regresar</a>
    </div>

    <section class="form-container page-form">
        <form id="formulario">
            <div class="form-field">
                <label for="nombre">Nombre y apellido</label>
                <input
                    type="text"
                    name="nombre"
                    id="nombre"
                    placeholder="Ej. Carlos Pérez"
                />
            </div>

            <div class="form-field">
                <label for="telefono">Teléfono</label>
                <input
                    type="text"
                    name="telefono"
                    id="telefono"
                    placeholder="Ej. 3001234567"
                />
            </div>

            <div class="form-field">
                <label for="cedula">Cédula</label>
                <input
                    type="number"
                    name="cedula"
                    id="cedula"
                    placeholder="Ej. 1234567890"
                    min="0"
                />
            </div>

            <div class="form-actions">
                <button type="submit">Agregar cliente</button>
            </div>
        </form>
    </section>

    <div id="overlay" class="overlay oculto"> 
        <div id="modal" class="modal"></div>
    </div>

</Layout>

<script>

    import { mostrarError, mostrarMensaje } from '@/utils/helpers/mensajes.js';

    const formulario = document.getElementById('formulario') as HTMLFormElement;

    formulario.addEventListener('submit', async (event : SubmitEvent) => { 
        
        event.preventDefault();

        const formData = new FormData(formulario);
        const nombre = (formData.get('nombre') as string).trim();
        const telefono = (formData.get('telefono') as string).trim();
        const cedulaText = formData.get('cedula') as string;

        if (nombre === '' || telefono === '' || cedulaText === '') {
            mostrarError('Todos los campos son obligatorios');
            return;
        }

        const telefonoRegex = /^\d+$/; 
        if (!telefonoRegex.test(telefono)) {
            mostrarError('El número de teléfono debe contener solo números');
            return;
        }

        const cedulaRegex = /^[1-9]\d*$/;
        if (!cedulaRegex.test(cedulaText)) {
            mostrarError("La cédula debe ser un número entero positivo mayor a cero");
            return;
        }

        const cedula = parseInt(cedulaText);

        const response = await fetch("/api/clientes", {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ nombre, telefono, cedula })
        });

        if (!response.ok) {
            if (response.status === 409) {
                const mensaje = await response.text();
                mostrarError(mensaje);
            } else {
                mostrarError('Error al agregar cliente: ' + response.status);
            }
            return;
        }

        const data = await response.json();
        mostrarMensaje(data.message);
        setTimeout(() => {
            window.location.href = '/clientes';
        }, 1000);
    });
    
</script>
