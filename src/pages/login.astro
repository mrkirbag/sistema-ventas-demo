        pointer-events: auto;
    }

    .oculto {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
    }

    .mensaje-exito {
        border: 6px solid var(--success-color);
    }

    .mensaje-error {
        border: 6px solid var(--danger-color);
    }

</style>