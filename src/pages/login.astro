        font-family: 'Archivo Black', sans-serif;
        letter-spacing: 1px;
    }

    form {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    form div {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    input {
        width: 300px;
        padding: 0.5rem;
