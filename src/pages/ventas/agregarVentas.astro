---
import Layout from '../../layouts/Layout.astro';
import { verificarToken } from '@/utils/auth.js';

const usuario = verificarToken(Astro.request);
if (!usuario) {
    return Astro.redirect('/login');
}

const fechaVenezuela = new Intl.DateTimeFormat('es-VE', {
        timeZone: 'America/Caracas',
        year: 'numeric',
        month: '2-digit',
        day: '2-digit'
    }).format(new Date());

const [dia, mes, ano] = fechaVenezuela.split('/');
const fechaCompleta = `${ano}-${mes}-${dia}`;
---

<Layout>
    <header class="page-header">
        <p class="eyebrow">Gestión comercial</p>
        <h1>Nueva venta</h1>
        <p class="page-intro">Agrega productos al carrito, confirma el detalle y completa la venta con el cliente y el tipo de pago.</p>
    </header>

    <div class="btn-add_container">
        <a class="btn-add" href="/ventas">Regresar</a>
    </div>

    <main class="venta-flow">
        <section class="venta-panel">
            <div class="panel-heading">
                <span class="step-badge">1</span>
                <div>
                    <p class="eyebrow">Productos</p>
                    <h2>Agregar al carrito</h2>
                </div>
            </div>

            <section class="form-container page-form venta-form">
                <form>
                    <div class="form-field">
                        <label for="fecha">Fecha de venta</label>
                        <input type="date" name="fecha" id="fecha" value={fechaCompleta}/>
                    </div>

                    <div id="productos-container" class="producto-module">
                        <div class="form-field producto-module_search">
                            <label for="busquedaProductos">Buscar producto</label>
                            <input type="text" id="busquedaProductos" placeholder="Nombre o código del producto" />
                        </div>

                        <div class="form-field producto-module_select">
                            <label for="productoSelect">Producto</label>
                            <select name="producto" id="productoSelect"></select>
                        </div>

                        <div class="form-field">
                            <label for="cantidad">Cantidad</label>
                            <input type="text" id="cantidad" placeholder="Ej. 2"/>
                        </div>

                        <div class="form-field">
                            <label for="precio">Precio por unidad (USD)</label>
                            <input type="text" id="precio" placeholder="0.00"/>
                            <span id="precioPesos" class="precio-referencia"></span>
                        </div>

                        <div class="form-actions producto-module_actions">
                            <button type="button" id="agregarProducto">Agregar producto</button>
                        </div>
                    </div>
                </form>
            </section>
        </section>

        <section class="venta-panel invoice-table-card">
            <div class="table-heading">
                <div>
                    <p class="eyebrow">Detalle</p>
                    <h2>Productos seleccionados</h2>
                </div>
                <p class="table-caption">Revisa cantidades y subtotales antes de continuar.</p>
            </div>

            <div class="table-wrap">
                <table>
                    <thead id="headerTablaProductos" style="opacity: 0;">
                        <tr>
                            <th>Producto</th>
                            <th>Precio por unidad</th>
                            <th>Cantidad</th>
                            <th>Subtotal</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="listaProductos">
                    </tbody>
                </table>
            </div>
        </section>

        <div class="confirm-step">
            <button id="btnConfirmacion" class="btn-confirmar" disabled style="display: none;">
                Continuar con la venta
            </button>
        </div>

        <section class="form-container page-form venta-panel checkout-panel" id="moduloDatosCompletar" style="display: none;">
            <div class="panel-heading">
                <span class="step-badge">2</span>
                <div>
                    <p class="eyebrow">Finalizar</p>
                    <h2>Datos de la venta</h2>
                </div>
            </div>

            <form class="checkout-form">
                <div class="form-field">
                    <label for="busquedaClientes">Buscar cliente</label>
                    <input type="text" id="busquedaClientes" placeholder="Buscar por cédula" />
                </div>

                <div class="form-field select-container password-container">
                    <label for="cliente">Cliente</label>
                    <select name="cliente" id="cliente"></select>
                    <span class="btn-cliente" id="abrirMenuClienteNuevo" title="Registrar nuevo cliente">+</span>
                </div>

                <div id="moduloAgregarClienteNuevo" class="cliente-nuevo-panel" style="display: none;">
                    <p class="cliente-nuevo_title">Registrar cliente no existente</p>
                    <div class="form-field">
                        <label for="nombre">Nombre y apellido</label>
                        <input type="text" name="nombre" id="nombre" placeholder="Ej. Carlos Pérez" />
                    </div>
                    <div class="form-field">
                        <label for="telefono">Teléfono</label>
                        <input type="text" name="telefono" id="telefono" placeholder="Ej. 3001234567" />
                    </div>
                    <div class="form-field">
                        <label for="cedula">Cédula</label>
                        <input type="number" name="cedula" id="cedula" placeholder="Ej. 1234567890" min="0"/>
                    </div>
                    <div class="form-actions">
                        <button type="button" id="btnAgregarClienteNuevo">Registrar cliente</button>
                    </div>
                </div>

                <div class="form-field" id="tipoPago-container">
                    <label for="tipoPago">Tipo de pago</label>
                    <select name="tipoPago" id="tipoPago">
                        <option value="">Selecciona el tipo de pago</option>
                        <option value="contado">De contado</option>
                        <option value="credito">A crédito</option>
                    </select>
                </div>

                <div class="total-box checkout-total">
                    <p class="total-box_label">Total de la venta</p>
                    <p id="totalDeVenta" class="total-box_amount">—</p>
                </div>

                <div class="form-actions checkout-actions">
                    <button id="btnFinalizar" type="button">Confirmar venta</button>
                </div>
            </form>
        </section>
    </main>

    <div id="overlay" class="overlay oculto"> 
        <div id="modal" class="modal"></div>
    </div>
</Layout>

<style>
    .venta-flow {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .venta-panel,
    .invoice-table-card {
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(31, 10, 82, 0.08);
        box-shadow: 0 18px 32px rgba(15, 5, 41, 0.08);
    }

    .venta-panel {
        padding: 1.15rem;
    }

    .panel-heading {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        margin-bottom: 1rem;
    }

    .step-badge {
        display: grid;
        place-items: center;
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: #fff;
        font-family: "Archivo Black", sans-serif;
        font-size: 1rem;
        flex-shrink: 0;
        box-shadow: 0 10px 20px rgba(15, 5, 41, 0.18);
    }

    .panel-heading h2 {
        margin: 0;
        font-size: 1.2rem;
    }

    .venta-form {
        width: 100%;
        margin: 0;
        padding: 0;
        background: transparent;
        border: none;
        box-shadow: none;
        backdrop-filter: none;
    }

    .producto-module {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem 1rem;
        padding: 1.1rem;
        border-radius: var(--radius-md);
        background: linear-gradient(180deg, rgba(236, 231, 246, 0.5), rgba(255, 255, 255, 0.72));
        border: 1px solid rgba(31, 10, 82, 0.08);
    }

    .producto-module_search,
    .producto-module_select,
    .producto-module_actions {
        grid-column: 1 / -1;
    }

    .precio-referencia {
        margin-top: 0.35rem;
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--secondary-color);
    }

    .invoice-table-card {
        padding: 1.15rem;
    }

    .table-heading {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .table-heading h2 {
        margin: 0;
        font-size: 1.2rem;
    }

    .table-caption {
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #4f3d78;
        text-align: right;
        max-width: 28ch;
        line-height: 1.5;
    }

    .confirm-step {
        display: flex;
        justify-content: center;
    }

    .btn-confirmar {
        appearance: none;
        border: none;
        border-radius: 999px;
        padding: 0.75rem 1.4rem;
        font-size: 0.86rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: #fff;
        box-shadow: 0 10px 24px rgba(15, 5, 41, 0.22);
        transition:
            transform 160ms ease,
            box-shadow 160ms ease,
            opacity 160ms ease;
    }

    .btn-confirmar:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 14px 26px rgba(15, 5, 41, 0.22);
        cursor: pointer;
    }

    .btn-confirmar:disabled {
        opacity: 0.55;
        cursor: not-allowed;
    }

    .checkout-panel {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        width: 100%;
        max-width: none;
    }

    .checkout-form {
        align-items: start;
    }

    .checkout-form .select-container {
        grid-template-columns: 1fr auto;
        align-items: end;
    }

    .checkout-form .select-container label {
        grid-column: 1 / -1;
    }

    .btn-cliente {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 44px;
        width: 44px;
        border-radius: 50%;
        cursor: pointer;
        font-weight: bold;
        font-size: 1.2rem;
        color: #fff;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        box-shadow: 0 8px 18px rgba(15, 5, 41, 0.18);
        transition: transform 160ms ease, box-shadow 160ms ease;
        align-self: end;
    }

    .btn-cliente:hover {
        transform: translateY(-1px);
        box-shadow: 0 12px 22px rgba(15, 5, 41, 0.22);
    }

    .cliente-nuevo-panel {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem 1rem;
        padding: 1rem;
        border-radius: var(--radius-md);
        background: rgba(236, 231, 246, 0.45);
        border: 1px dashed rgba(31, 10, 82, 0.18);
    }

    .cliente-nuevo_title {
        grid-column: 1 / -1;
        margin: 0 0 0.15rem;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--secondary-color);
    }

    .cliente-nuevo-panel .form-actions {
        grid-column: 1 / -1;
    }

    .checkout-total {
        grid-column: 1 / -1;
        width: min(100%, 420px);
        margin-left: auto;
        padding: 1rem 1.1rem;
        border-radius: 22px;
        background: linear-gradient(135deg, #dbeafe, #bfdbfe);
        color: #0f172a;
        border: 1px solid rgba(37, 99, 235, 0.18);
        box-shadow: 0 18px 28px rgba(37, 99, 235, 0.14);
    }

    .checkout-total p {
        color: inherit;
    }

    .total-box_label {
        margin: 0 0 0.5rem;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #1d4ed8;
    }

    .total-box_amount {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 800;
        line-height: 1.2;
        color: #0f172a;
    }

    .checkout-actions {
        grid-column: 1 / -1;
        justify-content: flex-end;
    }

    @media (max-width: 768px) {
        .producto-module,
        .cliente-nuevo-panel,
        .checkout-form {
            grid-template-columns: 1fr;
        }

        .table-heading {
            flex-direction: column;
        }

        .table-caption {
            text-align: left;
            max-width: none;
        }

        .checkout-total {
            width: 100%;
            margin-left: 0;
        }

        .btn-confirmar {
            width: 100%;
            min-height: 44px;
        }

        .checkout-actions {
            justify-content: stretch;
        }

        .checkout-actions button {
            width: 100%;
        }
    }
</style>

<script>

    import { mostrarError, mostrarMensaje } from '@/utils/helpers/mensajes.js';
    import { cambioUSDaCOP } from '@/utils/helpers/cambioMoneda.js';

    interface Cliente {
        id: number;
        nombre: string;
        cedula: string;
        telefono: string;
    }

    interface Producto {
        codigo: string;
        nombre: string;
        precio: number;
        cantidad: number;
        id: number;

        stock: number;
        costo: number;
        venta: number;
        unidad_medida: string;
    }

    const btnAbrirMenuClienteNuevo = document.getElementById("abrirMenuClienteNuevo") as HTMLSpanElement;
    const btnAgregarClienteNuevo = document.getElementById("btnAgregarClienteNuevo") as HTMLButtonElement;

    document.addEventListener("DOMContentLoaded", () => {
        rellenarSelectClientes();
        rellenarSelectProductos();
    }); 
    
    async function rellenarSelectClientes() {

        const selectClientes = document.getElementById("cliente") as HTMLSelectElement;
        const busqueda = document.getElementById("busquedaClientes") as HTMLInputElement;

        let clientesListados : Cliente[] = [];

        try {
            const response = await fetch("/api/clientes");
            const data = await response.json();

            clientesListados = Array.isArray(data) ? data : [];

            const renderOpciones = (clientes : Cliente[]) => {
                selectClientes.innerHTML = "";

                const defaultOption = document.createElement("option");
                defaultOption.value = "";
                defaultOption.textContent = "Selecciona un cliente";
                defaultOption.disabled = true;
                defaultOption.selected = true;
                selectClientes.appendChild(defaultOption);

                if (clientes.length === 0) {
                    const noResultsOption = document.createElement("option");
                    noResultsOption.value = "";
                    noResultsOption.textContent = "— Sin coincidencias para la búsqueda —";
                    noResultsOption.disabled = true;
                    selectClientes.appendChild(noResultsOption);
                    return;
                }

                clientes.forEach(cliente => {
                    const option = document.createElement("option") as HTMLOptionElement;
                    option.value = (cliente.id).toString();
                    option.textContent = `${cliente.nombre.toUpperCase()} - ${cliente.cedula}`;
                    selectClientes.appendChild(option);
                });
            };

            renderOpciones(clientesListados);

            busqueda.addEventListener("input", () => {
                const filtro = busqueda.value.trim();

                if (!filtro) {
                    renderOpciones(clientesListados);
                    return;
                }

                const clientesFiltrados = clientesListados.filter(cliente =>
                    String(cliente.cedula || "").includes(filtro)
                );

                renderOpciones(clientesFiltrados);
            });

        } catch (error) {
            console.error("Error al cargar los clientes:", error);
        }
    }

    async function rellenarSelectProductos() {

        const busqueda = document.getElementById("busquedaProductos") as HTMLInputElement;
        const productoSelect = document.getElementById("productoSelect") as HTMLSelectElement;

        let productosListados : Producto[] = [];

        try {

            const response = await fetch("/api/productos");
            const data = await response.json();

            productosListados = Array.isArray(data) ? data : [];

            const renderOpciones = (productos : Producto[]) => {
                productoSelect.innerHTML = "";

                const defaultOption = document.createElement("option");
                defaultOption.value = "";
                defaultOption.textContent = "Selecciona un producto";
                defaultOption.disabled = true;
                defaultOption.selected = true;
                productoSelect.appendChild(defaultOption);

                if (productos.length === 0) {
                    const noResultsOption = document.createElement("option");
                    noResultsOption.value = "";
                    noResultsOption.textContent = "— Sin coincidencias para la búsqueda —";
                    noResultsOption.disabled = true;
                    productoSelect.appendChild(noResultsOption);
                    return;
                }

                productos.forEach(producto => {
                    const option = document.createElement("option");
                    option.value = producto.id.toString();
                    option.textContent = `${producto.codigo.toUpperCase()} - ${producto.nombre} - ${producto.stock} ${producto.unidad_medida} - ${producto.venta}USD`;
                    productoSelect.appendChild(option);
                });
            };

            renderOpciones(productosListados);

            busqueda.addEventListener("input", () => {
                const filtro = busqueda.value.trim().toLowerCase();

                if (!filtro) {
                    renderOpciones(productosListados);
                    return;
                }

                const productosFiltrados = productosListados.filter(producto => {
                    const nombre = String(producto.nombre || "").toLowerCase();
                    const codigo = String(producto.codigo || "").toLowerCase();
                    return nombre.includes(filtro) || codigo.includes(filtro);
                });

                renderOpciones(productosFiltrados);
            });


        } catch (error) {
            console.error("Error al cargar los productos:", error);
        }
    }

    const productoSelect = document.getElementById("productoSelect") as HTMLSelectElement;
    const precioInput = document.getElementById("precio") as HTMLInputElement;
    const precioPesos = document.getElementById("precioPesos") as HTMLSpanElement;

    productoSelect.addEventListener("change", async () => {
        const productoId = productoSelect.value;

        if (!productoId) {
            precioInput.value = "";
            precioPesos.textContent = "";
            return;
        }

        try {
            const response = await fetch(`/api/productos/${productoId}`);

            if (!response.ok) {
                console.error("Error al obtener el producto:", response.status);
                precioInput.value = "";
                precioPesos.textContent = "";
                return;
            }

            const producto = await response.json();

            if (typeof producto.venta === "number") {
                precioInput.value = producto.venta.toFixed(2);
                const tasa = await cambioUSDaCOP();
                precioPesos.textContent = `Referencia: ${Math.ceil(producto.venta * tasa)} COP`;
            } else {
                precioInput.value = "";
                precioPesos.textContent = "";
            }

        } catch (error) {
            console.error("Error de red o parsing:", error);
            precioInput.value = "";
            precioPesos.textContent = "";
        }
    });

    const btnagregarProducto = document.getElementById("agregarProducto") as HTMLButtonElement;
    let productosSeleccionados : Producto[] = [];

    btnagregarProducto.addEventListener("click", async (e : Event) => {
            
        e.preventDefault();

        const productoId = productoSelect.value;
        const cantidadInput = document.getElementById("cantidad") as HTMLInputElement;
        const cantidad = parseFloat(cantidadInput.value.replace(",", "."));
        const precio = parseFloat(precioInput.value.replace(",", "."));


        try {
            const response = await fetch(`/api/productos/${productoId}`);
            if (!response.ok) {
                throw new Error('Error al obtener el producto: ' + response.status);
            }
            const producto = await response.json();

            if (!producto || !producto.stock) {
                mostrarError('Producto no encontrado o sin stock disponible');
                return;
            }

            if (isNaN(cantidad) || Number(cantidad) <= 0) {
                mostrarError("Ingresa una cantidad válida mayor a cero");
                return;
            }

            if (isNaN(precio) || Number(precio) <= 0) {
                mostrarError("El precio del producto no es válido");
                return;
            }

            if (Number(cantidad) > producto.stock) {
                mostrarError(`Cantidad insuficiente en stock. Stock disponible: ${producto.stock}`);
                return;
            }

            const tasa = await cambioUSDaCOP();

            const theader = document.getElementById("headerTablaProductos") as HTMLTableSectionElement;

            const btnConfirmacion = document.getElementById("btnConfirmacion") as HTMLButtonElement;

            const tablaProductos = document.getElementById("listaProductos") as HTMLTableSectionElement;
            const fila = document.createElement("tr");
            fila.innerHTML = `
                                <td data-label="Producto">
                                    <strong>${producto.nombre.toUpperCase()}</strong>
                                    <br />
                                    <span style="font-size: 0.78rem; color: var(--text-muted);">${producto.codigo}</span>
                                </td>
                                <td data-label="P. Unitario">
                                    <strong>${precio.toFixed(2)} USD</strong>
                                    <br />
                                    <span style="font-size: 0.78rem; color: var(--text-muted);">${Math.ceil(precio * tasa)} COP</span>
                                </td>
                                <td data-label="Cantidad">${cantidad} U.</td>
                                <td data-label="Subtotal">
                                    <strong>${(cantidad * precio).toFixed(2)} USD</strong>
                                    <br />
                                    <span style="font-size: 0.78rem; color: var(--text-muted);">${Math.ceil(cantidad * precio * tasa)} COP</span>
                                </td>
                            `;

            const tdAcciones = document.createElement('td');
            tdAcciones.classList.add('acciones');

            const btnEliminar = document.createElement('button');
            btnEliminar.type = 'button';
            btnEliminar.classList.add('btn-eliminar');
            btnEliminar.textContent = 'DEL';
            btnEliminar.addEventListener('click', () => {

                fila.remove();

                productosSeleccionados = productosSeleccionados.filter(p => p.codigo !== producto.codigo);
                
                if(tablaProductos.innerHTML.trim() === "") {
                    theader.style.opacity = "0";
                    btnConfirmacion.style.display = "none";
                    btnConfirmacion.disabled = true;
                } else {
                    theader.style.opacity = "1";
                    btnConfirmacion.style.display = "inline-block";
                    btnConfirmacion.disabled = false;
                }
            });

            tdAcciones.appendChild(btnEliminar);
            fila.appendChild(tdAcciones);
            tablaProductos.appendChild(fila);

            if(tablaProductos.innerHTML.trim() === "") {
                theader.style.opacity = "0";
                btnConfirmacion.style.display = "none";
                btnConfirmacion.disabled = true;
            } else {
                theader.style.opacity = "1";
                btnConfirmacion.style.display = "inline-block";
                btnConfirmacion.disabled = false;
            }

            productoSelect.value = "";
            cantidadInput.value = "";
            precioInput.value = "";
            precioPesos.textContent = "";

            productosSeleccionados.push({
                id: producto.id,
                nombre: producto.nombre,
                codigo: producto.codigo,
                precio: precio,
                cantidad: cantidad,
                stock: producto.stock,
                costo: producto.costo,
                venta: producto.venta,
                unidad_medida: producto.unidad_medida
            });

        } catch (error) {
            console.error("Error al obtener el producto:", error);
            return;
        }
    });

    const btnConfirmacion = document.getElementById("btnConfirmacion") as HTMLButtonElement;

    let totalDeVenta = 0;

    btnConfirmacion.addEventListener("click", async () => {
        
        const moduloDatosCompletar = document.getElementById("moduloDatosCompletar") as HTMLDivElement;
        moduloDatosCompletar.style.display = "flex";

        btnConfirmacion.disabled = true;
        btnConfirmacion.textContent = "Procesando...";

        const tasa = await cambioUSDaCOP();

        const total = productosSeleccionados.map(p => p.precio * p.cantidad).reduce((a, b) => a + b, 0);
        const totalTexto = document.getElementById("totalDeVenta") as HTMLParagraphElement;
        totalTexto.textContent = `${total.toFixed(2)} USD · ${Math.ceil(total * tasa)} COP`;
        totalDeVenta = total;

        moduloDatosCompletar.scrollIntoView({ behavior: 'smooth', block: 'start' });

    });

    btnAbrirMenuClienteNuevo.addEventListener("click", (e) => {
        e.preventDefault();
        const moduloAgregarCliente = document.getElementById("moduloAgregarClienteNuevo") as HTMLDivElement;

        moduloAgregarCliente.style.display = 
            moduloAgregarCliente.style.display === "none" ? "grid" : "none";
        btnAbrirMenuClienteNuevo.textContent = 
            moduloAgregarCliente.style.display === "grid" ? "−" : "+";
    }); 
    
    btnAgregarClienteNuevo.addEventListener("click", agregarClienteNuevo);

    async function agregarClienteNuevo(event : Event) {

        event.preventDefault();

        const nombre = (document.getElementById('nombre') as HTMLInputElement).value;
        const telefono = (document.getElementById('telefono') as HTMLInputElement).value;
        const cedulaText = (document.getElementById('cedula') as HTMLInputElement).value;

        if (nombre === '' || telefono === '' || cedulaText === '') {
            mostrarError('Todos los campos son obligatorios');
            return;
        }

        const telefonoRegex = /^\d+$/; 
        if (!telefonoRegex.test(telefono)) {
            mostrarError('El número de teléfono debe contener solo números');
            return;
        }

        const cedulaRegex = /^[1-9]\d*$/;
        if (!cedulaRegex.test(cedulaText)) {
            mostrarError("La cédula debe ser un número entero positivo mayor a cero");
            return;
        }

        const cedula = parseInt(cedulaText);

        const response = await fetch("/api/clientes", {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ nombre, telefono, cedula })
        });

        if (!response.ok) {
            if (response.status === 409) {
                const mensaje = await response.text();
                mostrarError(mensaje);
            } else {
                mostrarError('Error al agregar cliente: ' + response.status);
            }
            return;
        }

        const data = await response.json();
        const clienteAgregado = data.cliente[0];
        
        const selectClientes = document.getElementById("cliente") as HTMLSelectElement;
        const option = document.createElement("option");
        option.value = clienteAgregado.id;
        option.textContent = `${clienteAgregado.nombre.toUpperCase()} - ${clienteAgregado.cedula}`;
        selectClientes.appendChild(option);
        option.selected = true;

        (document.getElementById('nombre') as HTMLInputElement).value = '';
        (document.getElementById('telefono') as HTMLInputElement).value = '';
        (document.getElementById('cedula') as HTMLInputElement).value = '';
        btnAbrirMenuClienteNuevo.textContent = "+";
        const moduloAgregarCliente = document.getElementById("moduloAgregarClienteNuevo") as HTMLDivElement;
        moduloAgregarCliente.style.display = "none";

        mostrarMensaje('Cliente agregado exitosamente.');
    }

    const btnFinalizar = document.getElementById("btnFinalizar") as HTMLButtonElement;

    btnFinalizar.addEventListener("click", async e => {

        e.preventDefault();

        const fecha = (document.getElementById('fecha') as HTMLInputElement).value;
        const tipoPago = (document.getElementById('tipoPago') as HTMLSelectElement).value;
        const clienteId = (document.getElementById('cliente') as HTMLSelectElement).value;

        if (!fecha || !tipoPago || !clienteId) {
            mostrarError("Todos los campos son obligatorios");
            return;
        }

        if(fecha === '' || tipoPago === '' || clienteId === '') {
            mostrarError("Todos los campos son obligatorios");
            return;
        }

        if (productosSeleccionados.length === 0) {
            mostrarError("No hay productos seleccionados para la venta");
            return;
        }

        if (isNaN(totalDeVenta) || totalDeVenta <= 0) {
            mostrarError("El total de la venta no es válido");
            return;
        }

        try  {

            const response = await fetch("/api/ventas/completa", {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    fecha,
                    tipoPago,
                    clienteId,
                    totalDeVenta,
                    productos: productosSeleccionados.map(({ codigo, nombre, precio, cantidad, id }) => ({
                        idProducto: id,
                        codigo,
                        nombre,
                        precio,
                        cantidad
                    }))
                })
            });

            const data = await response.json();

            if (!response.ok) {
                mostrarError(data.error || 'Error al crear la venta');
                return;
            }

            mostrarMensaje('¡Venta finalizada correctamente!');

            setTimeout(() => {
                window.location.href = `/ventas/${data.ventaId}`;
            }, 1750);

        } catch (error) {
            console.error("Error al crear la venta:", error);
            mostrarError("Error al crear la venta. Por favor, inténtalo de nuevo.");
            return;
        }
    });

</script>
