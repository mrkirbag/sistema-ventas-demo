    btnImprimir?.addEventListener("click", async () => {
        if (reportesContainer.hidden || !reportesContainer.children.length) {
            mostrarError('No hay contenido disponible para imprimir');
            return;
        }

        btnImprimir.disabled = true;

        try {
            const imgData = await toPng(reportesContainer, { cacheBust: true, pixelRatio: 2 });
            const tituloReporte = reporteActivoTitulo.textContent?.trim() || 'REPORTE';

            imprimir({
                titulo: 'Impresion',
                tituloDocumento: tituloReporte,
                estilosExtra: 'body { text-align: center; } img { max-width: 100%; height: auto; }',
                contenido: `<img src="${imgData}" alt="Reporte" />`,
                onReady: (ventana: Window) => {
                    const img = ventana.document.querySelector('img');
                    const ejecutarImpresion = () => {
                        ventana.focus();
                        ventana.print();
                        ventana.close();
                    };

                    if (!img) return;

                    if (img.complete) {
                        ejecutarImpresion();
                        return;
                    }

                    img.addEventListener('load', ejecutarImpresion);
                },
            } as Parameters<typeof imprimir>[0]);
        } catch (error) {
            console.error('Error al imprimir:', error);
            mostrarError('No se pudo preparar la impresión');
        } finally {
            btnImprimir.disabled = false;
        }
    });

</script>
