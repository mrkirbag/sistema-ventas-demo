---
import Layout from '../layouts/Layout.astro';
import { verificarToken } from '../utils/auth.js';

const usuario = verificarToken(Astro.request);
if (!usuario) {
    return Astro.redirect('/login');
}
if (usuario.rol !== 'admin') {
    return Astro.redirect('/'); 
}
---

<Layout>
    <section class="reportes-hero">
        <p class="eyebrow">Inteligencia comercial</p>
        <h1>Reportes y Estadísticas</h1>
        <p>Explora el rendimiento del negocio con filtros de fecha, resúmenes visuales y salidas listas para compartir.</p>
    </section>

    <main class="form-container filtros-shell">
        <form>
            <div>
                <label for="desde">Desde:</label>
                <input type="date" id="desde" name="desde" required />
            </div>

            <div>
                <label for="hasta">Hasta:</label>
                <input type="date" id="hasta" name="hasta" required />
            </div>
        </form>
    </main>

    <section class="menu-reportes">
        <nav>
            <button type="button" id="masVendido" data-label="Rendimiento comercial">Rendimiento</button>
            <button type="button" id="stock" data-label="Baja existencia">Baja Existencia</button>
            <button type="button" id="caja" data-label="Reporte de caja">Reporte de Caja</button>
            <button type="button" id="ventas" data-label="Ventas totales">Ventas Totales</button>
            <button type="button" id="anuladas" data-label="Ventas anuladas">Anuladas</button>
            <button type="button" id="creditos" data-label="Ventas a crédito">Créditos</button>
        </nav>
    </section>

    <section class="reportes-panel">
        <header class="reportes-panel__header">
            <div class="reportes-panel__info">
                <p class="eyebrow">Resultados</p>
                <h2 id="reporte-activo-titulo">Selecciona un reporte</h2>
                <p id="reporte-activo-desc">Elige un tipo de reporte arriba y, si aplica, define el rango de fechas.</p>
            </div>

            <div class="reportes-toolbar" id="reportes-toolbar" hidden>
                <button type="button" class="btn-imprimir" id="imprimir" aria-label="Imprimir reporte">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="6 9 6 2 18 2 18 9"></polyline>
                        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                        <rect x="6" y="14" width="12" height="8"></rect>
                    </svg>
                    Imprimir reporte
                </button>
            </div>
        </header>

        <div id="reportes-empty" class="reportes-empty">
            <div class="reportes-empty__icon" aria-hidden="true">📊</div>
            <p class="reportes-empty__title">Sin resultados todavía</p>
            <p class="reportes-empty__text">Usa los botones superiores para generar gráficos, tablas o resúmenes de caja.</p>
        </div>

        <div id="reportes" class="reportes-output" hidden></div>
    </section>

    <div id="overlay" class="overlay oculto"> 
        <div id="modal" class="modal"></div>
    </div>
</Layout>

<style>

    .reportes-hero {
        padding: 1.6rem 1.8rem;
        border-radius: 28px;
        background: linear-gradient(135deg, rgba(15, 5, 41, 0.96), rgba(31, 10, 82, 0.92));
        color: #f8f5ff;
        display: grid;
        gap: 0.6rem;
        box-shadow: 0 18px 32px rgba(15, 5, 41, 0.14);
    }

    .eyebrow {
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(239, 233, 255, 0.68);
    }

    .reportes-hero h1 {
        max-width: none;
        color: #f8f5ff;
    }

    .reportes-hero p:not(.eyebrow) {
        max-width: 68ch;
        color: rgba(239, 233, 255, 0.82);
    }

    .filtros-shell {
        width: min(100%, 780px);
    }

    form {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .menu-reportes nav {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding: 1.25rem;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(31, 10, 82, 0.08);
        box-shadow: 0 18px 32px rgba(15, 5, 41, 0.08);
    }

    .menu-reportes button {
        white-space: nowrap;
    }

    .menu-reportes button.is-active {
        background: linear-gradient(135deg, #4d2ea3, #856fcc);
        box-shadow: 0 14px 28px rgba(77, 46, 163, 0.32);
        transform: translateY(-1px);
    }

    .reportes-panel {
        display: grid;
        gap: 1.25rem;
        padding: 1.35rem;
        border-radius: 28px;
        background: rgba(255, 255, 255, 0.86);
        border: 1px solid rgba(31, 10, 82, 0.08);
        box-shadow: 0 18px 32px rgba(15, 5, 41, 0.08);
    }

    .reportes-panel__header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .reportes-panel__info {
        display: grid;
        gap: 0.35rem;
        flex: 1;
        min-width: min(100%, 280px);
    }

    .reportes-panel__info .eyebrow {
        color: var(--secondary-color);
    }

    .reportes-panel__info h2 {
        font-size: 1.35rem;
        color: var(--primary-color);
        margin: 0;
    }

    .reportes-panel__info p:last-child {
        color: var(--text-muted);
        font-size: 0.92rem;
        max-width: 52ch;
    }

    .reportes-toolbar {
        display: flex;
        align-items: center;
        justify-content: flex-end;
    }

    .btn-imprimir {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        padding: 0.78rem 1.35rem;
        border: none;
        border-radius: 999px;
        background: linear-gradient(135deg, #0f0529, #4d2ea3);
        color: #fffaff;
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        box-shadow: 0 12px 26px rgba(15, 5, 41, 0.22);
        cursor: pointer;
        transition:
            transform 160ms ease,
            box-shadow 160ms ease,
            background 160ms ease;
    }

    .btn-imprimir:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 30px rgba(15, 5, 41, 0.28);
    }

    .btn-imprimir:active {
        transform: translateY(0);
    }

    .btn-imprimir svg {
        flex-shrink: 0;
    }

    .reportes-toolbar[hidden],
    .reportes-empty[hidden],
    .reportes-output[hidden] {
        display: none !important;
    }

    .reportes-empty {
        display: grid;
        place-items: center;
        gap: 0.45rem;
        min-height: 220px;
        padding: 2rem 1.5rem;
        border-radius: 22px;
        border: 1px dashed rgba(31, 10, 82, 0.16);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(237, 231, 248, 0.55));
        text-align: center;
    }

    .reportes-empty__icon {
        font-size: 2rem;
        line-height: 1;
        opacity: 0.85;
    }

    .reportes-empty__title {
        font-weight: 700;
        color: var(--secondary-color);
        font-size: 1rem;
    }

    .reportes-empty__text {
        color: var(--text-muted);
        font-size: 0.9rem;
        max-width: 42ch;
    }

    .reportes-output {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        width: 100%;
        overflow-x: auto;
    }

    @media (max-width: 640px) {
        form {
            grid-template-columns: 1fr;
        }

        .reportes-hero {
            padding: 1.3rem;
        }

        .reportes-panel__header {
            flex-direction: column;
        }

        .reportes-toolbar {
            width: 100%;
        }

        .btn-imprimir {
            width: 100%;
        }
    }

    @media (max-width: 600px) {
        .menu-reportes nav {
            flex-direction: column;
            align-items: stretch;
        }

        .menu-reportes button {
            width: 100%;
        }
    }

    :global(.grid-reportes) {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.2rem;
    }

    @media (max-width: 900px) {
        :global(.grid-reportes) {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        :global(.grid-reportes) {
            grid-template-columns: 1fr;
        }
    }

    :global(.card) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(237, 231, 248, 0.9));
        border-radius: 22px;
        padding: 1.2rem;
        text-align: center;
        box-shadow: 0 16px 28px rgba(15, 5, 41, 0.08);
        border: 1px solid rgba(31, 10, 82, 0.08);
    }

    :global(.card h3) {
        font-size: 0.95rem;
        margin-bottom: 0.5rem;
        color: var(--primary-color);
    }

    :global(.card p) {
        font-size: 1.4rem;
        font-weight: bold;
        margin: 0;
        color: var(--secondary-color); 
    }

    :global(.card small) {
        display: block;
        margin-top: 0.3rem;
        font-size: 0.9rem;
        color: var(--text-muted);
    }

    :global(.card.highlight) {
        background: linear-gradient(135deg, rgba(15, 5, 41, 0.96), rgba(31, 10, 82, 0.92));
        color: #fff;
    }

    :global(.card.highlight h3),
    :global(.card.highlight p),
    :global(.card.highlight small) {
        color: #fff;
    }

    .menu-reportes button:hover {
        scale: 1.03;
    }

    .menu-reportes button:active {
        scale: 0.98;
    }

    :global(.reporte-subseccion) {
        display: grid;
        gap: 0.85rem;
        padding: 1.1rem;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(31, 10, 82, 0.08);
    }

    :global(.reporte-subseccion h3) {
        font-size: 1rem;
        color: var(--secondary-color);
        margin: 0;
    }

    :global(.tabla-wrapper) {
        width: 100%;
        overflow-x: auto;
    }

    :global(table.tabla-reportes) {
        width: 100%;
        min-width: 520px;
        white-space: normal;
    }

</style>

<script>

    import { mostrarError } from '@/utils/helpers/mensajes.js';
    import { cambioUSDaCOP } from '@/utils/helpers/cambioMoneda.js';
    import { formatearFecha } from '@/utils/helpers/formateoFecha';
    import { renderChart, destroyCharts } from '@/utils/helpers/chart.js';
    import { imprimir } from '@/utils/helpers/imprimir.js';
    import { toPng } from "html-to-image";

    const masVendidoBtn = document.querySelector('#masVendido');
    const stockBtn = document.querySelector('#stock');
    const anuladasBtn = document.querySelector('#anuladas');
    const cajaBtn = document.querySelector('#caja');
    const ventasBtn = document.querySelector('#ventas');    
    const creditosBtn = document.querySelector('#creditos');
    const menuButtons = document.querySelectorAll('.menu-reportes button');
    const reportesContainer = document.getElementById('reportes') as HTMLDivElement;
    const reportesEmpty = document.getElementById('reportes-empty') as HTMLDivElement;
    const reportesToolbar = document.getElementById('reportes-toolbar') as HTMLDivElement;
    const reporteActivoTitulo = document.getElementById('reporte-activo-titulo') as HTMLHeadingElement;
    const reporteActivoDesc = document.getElementById('reporte-activo-desc') as HTMLParagraphElement;
    const btnImprimir = document.getElementById('imprimir') as HTMLButtonElement;

    interface Producto {
        codigo_producto: string;
        nombre_producto: string;
        cantidad_total: number;
        total_usd: number;
        unidad_medida: string;
    }

    interface VentaAnulada {
        fecha_venta: string;
        nombre_cliente: string;
        cedula_cliente: string;
        total_usd: number;
        tipo_pago: string;
        estado: string;
    }

    function setActiveButton(activeBtn: HTMLElement | null) {
        menuButtons.forEach((btn) => {
            btn.classList.toggle('is-active', btn === activeBtn);
        });
    }

    function setImprimirVisible(visible: boolean) {
        reportesToolbar.hidden = !visible;
    }

    function setResultadosVisibles(visible: boolean) {
        reportesContainer.toggleAttribute('hidden', !visible);
        reportesEmpty.toggleAttribute('hidden', visible);
    }

    function setEstadoInicial() {
        reportesContainer.toggleAttribute('hidden', true);
        reportesEmpty.toggleAttribute('hidden', false);
        setImprimirVisible(false);
    }

    function setEstadoCargando() {
        reportesContainer.toggleAttribute('hidden', true);
        reportesEmpty.toggleAttribute('hidden', true);
        setImprimirVisible(false);
    }

    function restablecerVistaInicial() {
        setActiveButton(null);
        setEstadoInicial();
        setReporteMeta('Selecciona un reporte', 'Elige un tipo de reporte arriba y, si aplica, define el rango de fechas.');
    }

    function setReporteMeta(titulo: string, descripcion: string) {
        reporteActivoTitulo.textContent = titulo;
        reporteActivoDesc.textContent = descripcion;
    }

    function mostrarResultados(titulo: string, descripcion: string) {
        setReporteMeta(titulo, descripcion);
        setResultadosVisibles(true);
        setImprimirVisible(true);
    }

    function resetContenedor() {
        destroyCharts('reportes');
        reportesContainer.innerHTML = '';
        reportesContainer.classList.remove('charts-grid');
        setEstadoCargando();
        setReporteMeta('Generando reporte…', 'Estamos preparando la información solicitada.');
    }

    setEstadoInicial();

    function prepararGraficos(cantidad = 1) {
        if (cantidad > 1) {
            reportesContainer.classList.add('charts-grid');
        }
    }

    function validarFechas(desde: string, hasta: string): boolean {
        if (!desde || !hasta) {
            mostrarError('Debe seleccionar ambas fechas');
            return false;
        }
        if (hasta < desde) {
            mostrarError('La fecha final no puede ser menor que la inicial');
            return false;
        }
        return true;
    }

    function getButtonMeta(button: HTMLElement) {
        return {
            titulo: button.dataset.label || button.textContent?.trim() || 'Reporte',
            descripcion: 'Resultados listos para revisión e impresión.',
        };
    }

    masVendidoBtn?.addEventListener("click", async (e: Event) => {

        e.preventDefault();
        const button = e.currentTarget as HTMLElement;
        resetContenedor();
        setActiveButton(button);

        const desde = (document.querySelector("#desde") as HTMLInputElement)?.value;
        const hasta = (document.querySelector("#hasta") as HTMLInputElement)?.value;

        if (!validarFechas(desde, hasta)) {
            restablecerVistaInicial();
            return;
        }

        try {
            const response = await fetch(`/api/reportes/productosMasVendidos?desde=${desde}&hasta=${hasta}`);
            if (!response.ok) throw new Error(`Error ${response.status}`);

            const productos: {
                mas_vendidos: Producto[];
                menos_vendidos: Producto[];
            } = await response.json();

            if (!productos || !Array.isArray(productos.mas_vendidos) || !Array.isArray(productos.menos_vendidos) || (productos.mas_vendidos.length === 0 && productos.menos_vendidos.length === 0)) {
                restablecerVistaInicial();
                mostrarError('No hay productos vendidos en ese rango de fecha');
                return;
            }

            const meta = getButtonMeta(button);
            mostrarResultados(meta.titulo, `Comparativo de productos entre ${desde} y ${hasta}.`);
            prepararGraficos(2);

            renderChart(
                "Productos Más Vendidos",
                productos.mas_vendidos.map((p: Producto) => p.nombre_producto.toUpperCase()),
                productos.mas_vendidos.map((p: Producto) => p.cantidad_total),
                { valueLabel: "Unidades vendidas" }
            );

            renderChart(
                "Productos Menos Vendidos",
                productos.menos_vendidos.map((p: Producto) => p.nombre_producto.toUpperCase()),
                productos.menos_vendidos.map((p: Producto) => p.cantidad_total),
                { valueLabel: "Unidades vendidas" }
            );

        } catch (error) {
            console.error("Error al generar reporte:", error);
            restablecerVistaInicial();
            mostrarError('No se pudo generar el reporte');
        }
    });

    stockBtn?.addEventListener('click', async (e: Event) => {

        e.preventDefault();
        const button = e.currentTarget as HTMLElement;
        resetContenedor();
        setActiveButton(button);

        try {
            const response = await fetch(`/api/reportes/menosStock`);
            if (!response.ok) throw new Error(`Error ${response.status}`);

            const productos = await response.json();

            if (!productos || !Array.isArray(productos.bajos) 
                || !Array.isArray(productos.agotados) 
                || (productos.bajos.length === 0 && productos.agotados.length === 0)
            ) {
                restablecerVistaInicial();
                mostrarError('No hay productos con poco stock');
                return;
            }

            const meta = getButtonMeta(button);
            mostrarResultados(meta.titulo, 'Inventario crítico y productos agotados en el sistema.');

            if (productos.bajos.length > 0) {
                renderChart(
                    "Productos Bajos en Stock",
                    productos.bajos.map((p: Producto) => p.nombre_producto.toUpperCase()),
                    productos.bajos.map((p: Producto) => p.cantidad_total),
                    { valueLabel: "Stock disponible" }
                );
            }

            if (productos.agotados.length > 0) {
                const tablaAgotados = `
                    <section class="reporte-subseccion">
                        <h3>Productos Agotados</h3>
                        <div class="tabla-wrapper">
                            <table class="tabla-reportes">
                                <thead>
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Código</th>
                                        <th>Cantidad</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${productos.agotados.map((p: Producto) => `
                                        <tr>
                                            <td>${p.nombre_producto.toUpperCase()}</td>
                                            <td>${p.codigo_producto}</td>
                                            <td>${p.cantidad_total} ${p.unidad_medida}</td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    </section>
                `;

                reportesContainer.insertAdjacentHTML('beforeend', tablaAgotados);
            }

        } catch (error) {
            console.error('Error al generar reporte:', error);
            restablecerVistaInicial();
            mostrarError('No se pudo generar el reporte');
        }
    });

    cajaBtn?.addEventListener('click', async (e: Event) => {

        e.preventDefault();
        const button = e.currentTarget as HTMLElement;
        resetContenedor();
        setActiveButton(button);

        const desde = (document.querySelector("#desde") as HTMLInputElement)?.value;
        const hasta = (document.querySelector("#hasta") as HTMLInputElement)?.value;

        if (!validarFechas(desde, hasta)) {
            restablecerVistaInicial();
            return;
        }

        try {
            const response = await fetch(`/api/reportes/ingresos?desde=${desde}&hasta=${hasta}`);
            if (!response.ok) throw new Error(`Error ${response.status}`);

            const ventas = await response.json();
            const tasa = await cambioUSDaCOP();
            const meta = getButtonMeta(button);

            mostrarResultados(meta.titulo, `Resumen financiero del ${desde} al ${hasta}.`);

            reportesContainer.innerHTML = `
                <div class="grid-reportes">
                    <div class="card">
                        <h3>Nro. Ventas a Contado</h3>
                        <p>${ventas.resumen.ventas_contado}</p>
                    </div>
                    <div class="card">
                        <h3>Nro. Abonos</h3>
                        <p>${ventas.resumen.abonos_realizados}</p>
                    </div>
                    <div class="card highlight">
                        <h3>Total en Caja</h3>
                        <p>${Number(ventas.resumen.total_ventas_contado + ventas.resumen.total_abonos_realizados).toFixed(2)} USD</p>
                        <small>${Math.ceil((ventas.resumen.total_ventas_contado + ventas.resumen.total_abonos_realizados) * tasa)} COP</small>
                    </div>
                    <div class="card">
                        <h3>Total de Contado</h3>
                        <p>${ventas.resumen.total_ventas_contado.toFixed(2)} USD</p>
                        <small>${Math.ceil(ventas.resumen.total_ventas_contado * tasa)} COP</small>
                    </div>
                    <div class="card">
                        <h3>Total de Abonos</h3>
                        <p>${ventas.resumen.total_abonos_realizados.toFixed(2)} USD</p>
                        <small>${Math.ceil(ventas.resumen.total_abonos_realizados * tasa)} COP</small>
                    </div>
                    <div class="card">
                        <h3>Ganancia Neta de Contado</h3>
                        <p>${ventas.resumen.margen_ganancia.toFixed(2)} USD</p>
                        <small>${Math.ceil(ventas.resumen.margen_ganancia * tasa)} COP</small>
                    </div>
                </div>
            `;

            renderChart("Reporte de Caja en USD", [
                "Contado",
                "Crédito",
                "Abonos",
                "Total",
                "Ganancia"
            ], [
                Math.ceil(ventas.resumen.total_ventas_contado),
                Math.ceil(ventas.resumen.total_ventas_credito),
                Math.ceil(ventas.resumen.total_abonos_realizados),
                Math.ceil(ventas.resumen.total_en_caja),
                Math.ceil(ventas.resumen.margen_ganancia),
            ], {
                valueLabel: "USD",
                horizontal: false,
            });

        } catch (error) {
            console.error('Error al generar reporte:', error);
            restablecerVistaInicial();
            mostrarError('No se pudo generar el reporte');
        }
    });

    ventasBtn?.addEventListener('click', async (e: Event) => {

        e.preventDefault();
        const button = e.currentTarget as HTMLElement;
        resetContenedor();
        setActiveButton(button);

        const desde = (document.querySelector("#desde") as HTMLInputElement)?.value;
        const hasta = (document.querySelector("#hasta") as HTMLInputElement)?.value;

        if (!validarFechas(desde, hasta)) {
            restablecerVistaInicial();
            return;
        }

        try {
            const response = await fetch(`/api/reportes/ventasTotales?desde=${desde}&hasta=${hasta}`);
            if (!response.ok) throw new Error(`Error ${response.status}`);

            const ventas : VentaAnulada[] = await response.json();

            if (ventas.length === 0) {
                restablecerVistaInicial();
                mostrarError('No hay ventas en ese rango de fecha');
                return;
            }

            const tasa = await cambioUSDaCOP();
            const meta = getButtonMeta(button);
            mostrarResultados(meta.titulo, `${ventas.length} venta(s) encontradas entre ${desde} y ${hasta}.`);

            const tabla = document.createElement('div');
            tabla.className = 'tabla-wrapper';
            tabla.innerHTML = `
                <table class="tabla-reportes">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Monto</th>
                            <th>Tipo de Pago</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${ventas.map(v => `
                            <tr>
