---
import Layout from '../layouts/Layout.astro';
import { verificarToken } from '@/utils/auth.js';

const usuario = verificarToken(Astro.request);
if (!usuario) {
    return Astro.redirect('/login');
}
---

<Layout>
    <header class="page-header">
        <p class="eyebrow">Gestión comercial</p>
        <h1>Presupuestos</h1>
        <p class="page-intro">Arma cotizaciones con productos del inventario, revisa los totales y genera un documento listo para imprimir.</p>
    </header>

    <main class="presupuesto-flow">
        <section class="presupuesto-panel">
            <div class="panel-heading">
                <span class="step-badge">1</span>
                <div>
                    <p class="eyebrow">Productos</p>
                    <h2>Agregar al presupuesto</h2>
                </div>
            </div>

            <section class="form-container page-form presupuesto-form">
                <form>
                    <div id="productos-container" class="producto-module">
                        <div class="form-field producto-module_search">
                            <label for="busquedaProductos">Buscar producto</label>
                            <input type="text" id="busquedaProductos" placeholder="Nombre o código del producto" />
                        </div>

                        <div class="form-field producto-module_select">
                            <label for="productoSelect">Producto</label>
                            <select name="producto" id="productoSelect"></select>
                        </div>

                        <div class="form-field">
                            <label for="cantidad">Cantidad</label>
                            <input type="number" min="1" id="cantidad" placeholder="Ej. 2"/>
                        </div>

                        <div class="form-field">
                            <label for="precio">Precio por unidad (USD)</label>
                            <input type="text" id="precio" placeholder="0.00"/>
                            <span class="precio-referencia" id="precioReferencia">Referencia: 0 COP</span>
                        </div>

                        <div class="form-actions producto-module_actions">
                            <button type="button" id="agregarProducto">Agregar producto</button>
                        </div>
                    </div>
                </form>
            </section>
        </section>

        <section class="presupuesto-panel invoice-table-card">
            <div class="table-heading">
                <div>
                    <p class="eyebrow">Detalle</p>
                    <h2>Productos cotizados</h2>
                </div>
                <p class="table-caption">Revisa cantidades y subtotales antes de imprimir.</p>
            </div>

            <div class="table-wrap">
                <table id="contenidoImpresion">
                    <thead id="headerTablaProductos" style="opacity: 0;">
                        <tr>
                            <th>Producto</th>
                            <th>Precio por unidad</th>
                            <th>Cantidad</th>
                            <th>Subtotal</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="listaProductos">
                    </tbody>
                </table>
            </div>
        </section>

        <section class="presupuesto-summary-card" aria-live="polite">
            <div class="summary-icon" aria-hidden="true">$</div>
            <div>
                <p class="summary-eyebrow">Estado del presupuesto</p>
                <p class="summary-text" id="resumenPresupuesto">Agrega productos para comenzar el presupuesto.</p>
                <p class="summary-subtext" id="resumenItems"></p>
            </div>
        </section>

        <section class="presupuesto-footer" id="presupuestoFooter" hidden>
            <section class="total-box" id="totalResumen">
                <p class="total-box_label">Total del presupuesto</p>
                <div class="total-box_values">
                    <div>
                        <span class="total-box_caption">USD</span>
                        <strong id="totalUSD">0.00</strong>
                    </div>
                    <div>
                        <span class="total-box_caption">COP</span>
                        <strong id="totalCOP">0</strong>
                    </div>
                </div>
            </section>

            <div class="btns-container" id="btns">
                <button type="button" id="imprimir" disabled>Imprimir presupuesto</button>
                <button type="button" id="reiniciar" class="btn-secundario" disabled>Cancelar</button>
            </div>
        </section>
    </main>

    <div id="mensaje"></div>
    <div id="overlay" class="overlay oculto">
        <div id="modal" class="modal"></div>
    </div>
</Layout>

<style>
    .presupuesto-flow {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .presupuesto-panel,
    .invoice-table-card {
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(31, 10, 82, 0.08);
        box-shadow: 0 18px 32px rgba(15, 5, 41, 0.08);
    }

    .presupuesto-panel {
        padding: 1.15rem;
    }

    .panel-heading {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        margin-bottom: 1rem;
    }

    .step-badge {
        display: grid;
        place-items: center;
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: #fff;
        font-family: "Archivo Black", sans-serif;
        font-size: 1rem;
        flex-shrink: 0;
        box-shadow: 0 10px 20px rgba(15, 5, 41, 0.18);
    }

    .panel-heading h2 {
        margin: 0;
        font-size: 1.2rem;
    }

    .presupuesto-form {
        width: 100%;
        margin: 0;
        padding: 0;
        background: transparent;
        border: none;
        box-shadow: none;
        backdrop-filter: none;
    }

    .producto-module {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem 1rem;
        padding: 1.1rem;
        border-radius: var(--radius-md);
        background: linear-gradient(180deg, rgba(236, 231, 246, 0.5), rgba(255, 255, 255, 0.72));
        border: 1px solid rgba(31, 10, 82, 0.08);
    }

    .producto-module_search,
    .producto-module_select,
    .producto-module_actions {
        grid-column: 1 / -1;
    }

    .precio-referencia {
        margin-top: 0.35rem;
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--secondary-color);
    }

    .invoice-table-card {
        padding: 1.15rem;
    }

    .table-heading {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .table-heading h2 {
        margin: 0;
        font-size: 1.2rem;
    }

    .table-caption {
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #4f3d78;
        text-align: right;
        max-width: 28ch;
        line-height: 1.5;
    }

    .presupuesto-summary-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.15rem;
        border-radius: var(--radius-lg);
        background: linear-gradient(135deg, rgba(31, 10, 82, 0.06), rgba(217, 209, 236, 0.42));
        border: 1px solid rgba(31, 10, 82, 0.1);
        box-shadow: var(--shadow-card);
    }

    .summary-icon {
        display: grid;
        place-items: center;
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: #fff;
        font-family: "Archivo Black", sans-serif;
        font-size: 1.35rem;
        flex-shrink: 0;
        box-shadow: 0 10px 22px rgba(15, 5, 41, 0.2);
    }

    .summary-eyebrow {
        margin: 0 0 0.2rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--secondary-color);
    }

    .summary-text {
        margin: 0;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--primary-strong);
        line-height: 1.5;
    }

    .summary-subtext {
        margin: 0.25rem 0 0;
        font-size: 0.82rem;
        color: var(--text-muted);
        font-weight: 600;
    }

    .presupuesto-footer {
        display: grid;
        gap: 1rem;
    }

    .presupuesto-footer[hidden] {
        display: none;
    }

    .total-box {
        width: min(100%, 420px);
        margin: 0 0 0 auto;
        padding: 1rem 1.1rem;
        border-radius: 22px;
        background: linear-gradient(135deg, #dbeafe, #bfdbfe);
        color: #0f172a;
        border: 1px solid rgba(37, 99, 235, 0.18);
        box-shadow: 0 18px 28px rgba(37, 99, 235, 0.14);
    }

    .total-box.is-empty {
        background: linear-gradient(135deg, #eff6ff, #dbeafe);
    }

    .total-box p,
    .total-box span,
    .total-box strong {
        color: inherit;
    }

    .total-box_label {
        margin: 0 0 0.75rem;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #1d4ed8;
    }

    .total-box_values {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem;
    }

    .total-box_values div {
        display: grid;
        gap: 0.25rem;
        padding: 0.85rem 0.9rem;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

    .total-box_caption {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #2563eb;
    }

    .total-box strong {
        font-size: 1.25rem;
        line-height: 1;
        color: #0f172a;
    }

    .btns-container {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .btns-container button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 148px;
        min-height: 44px;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: #fff;
        border-radius: 999px;
        padding: 0.72rem 1rem;
        font-size: 0.84rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        border: none;
        box-shadow: 0 10px 24px rgba(15, 5, 41, 0.22);
        transition: transform 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
    }

    .btns-container button:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 14px 28px rgba(15, 5, 41, 0.28);
        cursor: pointer;
    }

    .btns-container button:disabled {
        cursor: not-allowed;
        opacity: 0.55;
        box-shadow: none;
        transform: none;
    }

    .btn-secundario {
        background: rgba(15, 5, 41, 0.08) !important;
        color: var(--secondary-color) !important;
        border: 1px solid rgba(31, 10, 82, 0.16) !important;
        box-shadow: none !important;
    }

    .btn-secundario:hover:not(:disabled) {
        background: rgba(15, 5, 41, 0.12) !important;
        box-shadow: none !important;
    }

    :global(.monto-usd) {
        font-weight: 700;
        color: var(--primary-strong);
    }

    :global(.monto-cop) {
        font-size: 0.78rem;
        color: var(--text-muted);
    }

    @media (max-width: 768px) {
        .producto-module {
            grid-template-columns: 1fr;
        }

        .table-heading {
            flex-direction: column;
        }

        .table-caption {
            text-align: left;
            max-width: none;
        }

        .presupuesto-summary-card {
            align-items: flex-start;
            padding: 0.9rem 1rem;
        }

        .total-box {
            width: 100%;
            margin-inline: 0;
        }

        .total-box_values {
            grid-template-columns: 1fr;
        }

        .btns-container {
            justify-content: stretch;
        }

        .btns-container button {
            width: 100%;
            min-width: 0;
        }
    }
</style>

<script >

    import { cambioUSDaCOP } from "@/utils/helpers/cambioMoneda";
    import { imprimir } from '@/utils/helpers/imprimir.js';
    import { mostrarError } from "@/utils/helpers/mensajes";

    interface Producto {
        codigo: string;
        nombre: string;
        precio: number;
        cantidad: number;
        id: number;

        stock: number;
        costo: number;
        venta: number;
        unidad_medida: string;
    }

    function actualizarResumen(cantidadItems: number, totalUSD = 0, totalCOP = 0) {
        const resumen = document.getElementById('resumenPresupuesto') as HTMLParagraphElement;
        const resumenItems = document.getElementById('resumenItems') as HTMLParagraphElement;
        if (!resumen || !resumenItems) return;

        if (cantidadItems === 0) {
            resumen.textContent = 'Agrega productos para comenzar el presupuesto.';
            resumenItems.textContent = '';
            return;
        }

        const textoItems = cantidadItems === 1
            ? '1 producto en el presupuesto'
            : `${cantidadItems} productos en el presupuesto`;

        resumen.textContent = textoItems;
        resumenItems.textContent = `Total estimado: ${totalUSD.toFixed(2)} USD · ${totalCOP} COP`;
    }

    function togglePresupuestoActivo(activo: boolean) {
        const thead = document.querySelector('#headerTablaProductos') as HTMLTableSectionElement;
        const presupuestoFooter = document.querySelector('#presupuestoFooter') as HTMLElement;
        const btnImprimir = document.querySelector('#imprimir') as HTMLButtonElement;
        const btnCancelar = document.querySelector('#reiniciar') as HTMLButtonElement;

        thead.style.opacity = activo ? '1' : '0';
        presupuestoFooter.hidden = !activo;
        btnImprimir.disabled = !activo;
        btnCancelar.disabled = !activo;
    }

    // Impresion
    (document.querySelector('#imprimir') as HTMLButtonElement).addEventListener('click', () => {

        const tablaOriginal = document.querySelector('#contenidoImpresion') as HTMLTableElement;
        const totalUSD = (document.querySelector('#totalUSD') as HTMLElement)?.textContent || '0.00';
        const totalCOP = (document.querySelector('#totalCOP') as HTMLElement)?.textContent || '0';

        const filas = Array.from(tablaOriginal.querySelectorAll('tbody tr')).map(fila => {
            const celdas = fila.querySelectorAll('td');
            return `
            <tr>
                <td>${celdas[0]?.textContent}</td>
                <td>${celdas[1]?.textContent}</td>
                <td>${celdas[2]?.textContent}</td>
                <td>${celdas[3]?.textContent}</td>
            </tr>
            `;
        }).join('');

        imprimir({
            titulo: 'Presupuestos',
            tituloDocumento: 'PRESUPUESTO',
            estilosExtra: `
                .total-box {
                    margin-left: auto;
                    width: 260px;
                    border: 1px solid #000;
                    border-radius: 14px;
                    padding: 12px;
                }
                .total-box_label {
                    margin: 0 0 8px;
                    font-size: 10px;
                    font-weight: bold;
                    text-transform: uppercase;
                    letter-spacing: 0.08em;
                }
                .total-box_values {
                    display: table;
                    width: 100%;
                }
                .total-row {
                    display: table-row;
                }
                .total-row span,
                .total-row strong {
                    display: table-cell;
                    padding: 4px 0;
                }
                .total-row span {
                    font-size: 11px;
                    font-weight: bold;
                }
                .total-row strong {
                    font-size: 13px;
                    text-align: right;
                }
            `,
            contenido: `
                <table>
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Precio por Unidad</th>
                            <th>Cantidad</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${filas}
                    </tbody>
                </table>
                <div class="total-box">
                    <p class="total-box_label">Total del presupuesto</p>
                    <div class="total-box_values">
                        <div class="total-row">
                            <span>USD</span>
                            <strong>${totalUSD}</strong>
                        </div>
                        <div class="total-row">
                            <span>COP</span>
                            <strong>${totalCOP}</strong>
                        </div>
                    </div>
                </div>
            `,
        });
    });

    document.addEventListener('DOMContentLoaded', rellenarSelectProductos);
    async function rellenarSelectProductos() {

        const busqueda = document.getElementById("busquedaProductos") as HTMLInputElement;
        const productoSelect = document.getElementById("productoSelect") as HTMLSelectElement;

        let productosListados: Producto[] = [];

        try {

            const response = await fetch("/api/productos");
            const data = await response.json();

            productosListados = Array.isArray(data) ? data : [];

            const renderOpciones = (productos: Producto[]) => {
                productoSelect.innerHTML = "";

                const defaultOption = document.createElement("option");
                defaultOption.value = "";
                defaultOption.textContent = "Selecciona un producto";
                defaultOption.disabled = true;
                defaultOption.selected = true;
                productoSelect.appendChild(defaultOption);

                if (productos.length === 0) {
                    const noResultsOption = document.createElement("option");
                    noResultsOption.value = "";
                    noResultsOption.textContent = "— Sin coincidencias para la búsqueda —";
                    noResultsOption.disabled = true;
                    productoSelect.appendChild(noResultsOption);
                    return;
                }

                productos.forEach(producto => {
                    const option = document.createElement("option");
                    option.value = producto.id.toString();
                    option.textContent = `${producto.codigo.toUpperCase()} - ${producto.nombre} - ${producto.stock} ${producto.unidad_medida} - ${producto.venta}USD`;
                    productoSelect.appendChild(option);
                });
            };

            renderOpciones(productosListados);

            busqueda.addEventListener("input", () => {
                const filtro = busqueda.value.trim().toLowerCase();

                if (!filtro) {
                    renderOpciones(productosListados);
                    return;
                }

                const productosFiltrados = productosListados.filter(producto => {
                    const nombre = String(producto.nombre || "").toLowerCase();
                    const codigo = String(producto.codigo || "").toLowerCase();
                    return nombre.includes(filtro) || codigo.includes(filtro);
                });

                renderOpciones(productosFiltrados);
            });


        } catch (error) {
            console.error("Error al cargar los productos:", error);
        }
    }

    const btnReiniciar = document.querySelector('#reiniciar') as HTMLButtonElement;
    btnReiniciar.addEventListener('click', () => {
        window.location.reload();
    });

    const productoSelect = document.getElementById("productoSelect") as HTMLSelectElement;
    const precioInput = document.getElementById("precio") as HTMLInputElement;
    const precioReferencia = document.getElementById("precioReferencia") as HTMLSpanElement;

    function actualizarReferenciaPrecio(tasa: number) {
        const precio = parseFloat(precioInput.value);

        if (isNaN(precio) || precio <= 0) {
            precioReferencia.textContent = 'Referencia: 0 COP';
            return;
        }

        precioReferencia.textContent = `Referencia: ${Math.ceil(precio * tasa)} COP`;
    }

    precioInput.addEventListener('input', async () => {
        const tasa = await cambioUSDaCOP();
        actualizarReferenciaPrecio(tasa);
    });

    productoSelect.addEventListener("change", async () => {

        const productoId = productoSelect.value;
        const tasa = await cambioUSDaCOP();

        if (!productoId) {
            precioInput.value = "";
            actualizarReferenciaPrecio(tasa);
            return;
        }

        try {
            const response = await fetch(`/api/productos/${productoId}`);

            if (!response.ok) {
                console.error("Error al obtener el producto:", response.status);
                precioInput.value = "";
                actualizarReferenciaPrecio(tasa);
                return;
            }

            const producto = await response.json();

            if (typeof producto.venta === "number") {
                precioInput.value = producto.venta.toFixed(2);
                actualizarReferenciaPrecio(tasa);
            } else {
                precioInput.value = "";
                actualizarReferenciaPrecio(tasa);
            }

        } catch (error) {
            console.error("Error de red o parsing:", error);
            precioInput.value = "";
            actualizarReferenciaPrecio(tasa);
        }
    });

    const btnagregarProducto = document.getElementById("agregarProducto") as HTMLButtonElement;

    btnagregarProducto.addEventListener("click", async (e) => {

        e.preventDefault();

        const productoId = productoSelect.value;
        const cantidadInput = document.getElementById("cantidad") as HTMLInputElement;

        const cantidad = Number(cantidadInput.value);
        const precio = parseFloat(precioInput.value);

        try {

            const response = await fetch(`/api/productos/${productoId}`);
            if (!response.ok) {
                throw new Error('Error al obtener el producto: ' + response.status);
            }
            const producto = await response.json();

            if (!producto || !producto.stock) {
                mostrarError('Producto no encontrado o sin stock disponible');
                return;
            }
            if (isNaN(cantidad) || Number(cantidad) <= 0) {
                mostrarError("Ingresa una cantidad válida mayor a cero");
                return;
            }
            if (isNaN(precio) || Number(precio) <= 0) {
                mostrarError("El precio del producto no es válido");
                return;
            }
            if (Number(cantidad) > producto.stock) {
                mostrarError(`Cantidad insuficiente en stock. Stock disponible: ${producto.stock}`);
                return;
            }

            let productoSeleccionado = {
                codigo: producto.codigo,
                nombre: producto.nombre,
                cantidad,
                precio,
                subtotal: (precio * cantidad)
            }

            mostrarProductosEnTabla(productoSeleccionado)
            
        } catch (error) {
            console.error("Error al obtener el producto:", error);
            return;
        }
    });

    async function mostrarProductosEnTabla(productoSeleccionado : { codigo: string; nombre: string; cantidad: number; precio: number; subtotal: number; }) {
        
        const tbody = document.querySelector('#listaProductos') as HTMLTableSectionElement;
        const cantidadInput = document.getElementById("cantidad") as HTMLInputElement;
        const productoSelect = document.getElementById("productoSelect") as HTMLSelectElement;
        const precioInput = document.getElementById("precio") as HTMLInputElement;

        const tasa = await cambioUSDaCOP();
        let precioPesos = Math.ceil(tasa * productoSeleccionado.precio);
        let subtotalPesos = Math.ceil(tasa * productoSeleccionado.subtotal);

        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td data-label="Producto">
                <strong>${productoSeleccionado.nombre.toUpperCase()}</strong>
                <br />
                <span class="monto-cop">${productoSeleccionado.codigo.toUpperCase()}</span>
            </td>
            <td data-label="Precio por Unidad">
                <span class="monto-usd">${productoSeleccionado.precio.toFixed(2)} USD</span>
                <br />
                <span class="monto-cop">${precioPesos} COP</span>
            </td>
            <td data-label="Cantidad">${productoSeleccionado.cantidad}</td>
            <td data-label="Subtotal">
                <span class="subtotal monto-usd">${productoSeleccionado.subtotal.toFixed(2)} USD</span>
                <br />
                <span class="monto-cop">${subtotalPesos} COP</span>
            </td>
        `;

        const tdAcciones = document.createElement('td');
        tdAcciones.classList.add('acciones');

        const btnEliminar = document.createElement('button');
        btnEliminar.type = 'button';
        btnEliminar.classList.add('btn-eliminar');
        btnEliminar.textContent = 'DEL';
        btnEliminar.addEventListener('click', () => {
            tr.remove();
            totalizar();
            if (tbody && tbody.querySelectorAll('tr').length <= 0) {
                togglePresupuestoActivo(false);
            }
        });

        tdAcciones.appendChild(btnEliminar);
        tr.appendChild(tdAcciones);
        tbody.appendChild(tr);

        if (tbody && tbody.querySelectorAll('tr').length > 0) {
            togglePresupuestoActivo(true);
        }

        productoSelect.value = "";
        cantidadInput.value = "";
        precioInput.value = "";
        precioReferencia.textContent = 'Referencia: 0 COP';
        
        totalizar();
    }

    async function totalizar(){
        const elementosSubtotal = document.querySelectorAll('.subtotal') as NodeListOf<HTMLSpanElement>;
        const totalResumen = document.querySelector('#totalResumen') as HTMLElement;
        const totalUSDNode = document.querySelector('#totalUSD') as HTMLElement;
        const totalCOPNode = document.querySelector('#totalCOP') as HTMLElement;

        const valoresSubtotal = Array.from(elementosSubtotal)
            .map(el => {
                const texto = el.textContent.trim();
                const match = texto.match(/[\d,.]+/);
                return match ? parseFloat(match[0].replace(',', '')) : 0;
            });

        const tasa = await cambioUSDaCOP();

        let totalUSD = 0;

        valoresSubtotal.forEach(subtotal => {
            totalUSD += subtotal;
        });

        const totalCOP = Math.ceil(tasa * totalUSD);

        totalResumen.classList.toggle('is-empty', totalUSD <= 0);
        totalUSDNode.textContent = totalUSD.toFixed(2);
        totalCOPNode.textContent = totalCOP.toString();

        actualizarResumen(elementosSubtotal.length, totalUSD, totalCOP);
    }

</script>
