---
import Layout from '../layouts/Layout.astro';
import { verificarToken } from '@/utils/auth.js';

const usuario = verificarToken(Astro.request);
if (!usuario) {
    return Astro.redirect('/login');
}
---

<Layout>
    <header class="page-header">
        <p class="eyebrow">Cuentas por cobrar</p>
        <h1>Créditos</h1>
        <p class="page-intro">Consulta las ventas a crédito pendientes de pago, revisa el saldo de cada cliente y registra abonos.</p>
    </header>

    <div class="page-toolbar">
        <div class="input-busqueda_container">
            <input type="text" id="inputBusqueda" placeholder="Buscar por nombre o cédula..." />
        </div>
    </div>

    <section class="creditos-summary-card" aria-live="polite">
        <div class="summary-icon" aria-hidden="true">$</div>
        <div>
            <p class="summary-eyebrow">Cartera pendiente</p>
            <p class="summary-text" id="resumenCreditos">Cargando créditos pendientes...</p>
            <p class="summary-subtext" id="resumenMonto"></p>
        </div>
    </section>

    <div class="table-wrap">
        <table>
            <thead id="thead" style="display: none;">
                <tr>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Saldo pendiente</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="listaCreditos">
            </tbody>
        </table>
    </div>

    <div id="mensaje"></div>
    <div id="overlay" class="overlay oculto">
        <div id="modal" class="modal"></div>
    </div>
</Layout>

<style>
    .creditos-summary-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.15rem;
        border-radius: var(--radius-lg);
        background: linear-gradient(135deg, rgba(31, 10, 82, 0.06), rgba(217, 209, 236, 0.42));
        border: 1px solid rgba(31, 10, 82, 0.1);
        box-shadow: var(--shadow-card);
    }

    .summary-icon {
        display: grid;
        place-items: center;
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: #fff;
        font-family: "Archivo Black", sans-serif;
        font-size: 1.35rem;
        flex-shrink: 0;
        box-shadow: 0 10px 22px rgba(15, 5, 41, 0.2);
    }

    .summary-eyebrow {
        margin: 0 0 0.2rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--secondary-color);
    }

    .summary-text {
        margin: 0;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--primary-strong);
        line-height: 1.5;
    }

    .summary-subtext {
        margin: 0.25rem 0 0;
        font-size: 0.82rem;
        color: var(--text-muted);
        font-weight: 600;
    }

    :global(.status-badge) {
        display: inline-flex;
        align-items: center;
        padding: 0.32rem 0.7rem;
        border-radius: 999px;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border: 1px solid transparent;
    }

    :global(.status-badge--pendiente) {
        background: rgba(242, 200, 109, 0.22);
        color: #8a5b00;
        border-color: rgba(242, 200, 109, 0.45);
    }

    :global(.monto-usd) {
        font-weight: 700;
        color: var(--primary-strong);
    }

    :global(.monto-cop) {
        font-size: 0.78rem;
        color: var(--text-muted);
    }

    @media (max-width: 768px) {
        .creditos-summary-card {
            align-items: flex-start;
            padding: 0.9rem 1rem;
        }
    }
</style>

<script>

    import { noRegistros } from "@/utils/helpers/mensajes.js";
    import { cambioUSDaCOP } from "@/utils/helpers/cambioMoneda.js";
    import { formatearFecha } from "@/utils/helpers/formateoFecha.js";

    interface Credito {
        id_credito: number;
        fecha: string;
        nombre: string;
        cedula: string;
        saldo_pendiente: number;
        estado: string;
    }

    let todosLosCreditos: Credito[] = [];
    let tasaActual = 0;

    function actualizarResumen(creditos: Credito[], esBusqueda = false) {
        const resumen = document.getElementById('resumenCreditos') as HTMLParagraphElement;
        const resumenMonto = document.getElementById('resumenMonto') as HTMLParagraphElement;
        if (!resumen || !resumenMonto) return;

        if (creditos.length === 0) {
            if (esBusqueda && todosLosCreditos.length > 0) {
                resumen.textContent = 'Ningún crédito coincide con la búsqueda.';
            } else {
                resumen.textContent = 'No hay ventas a crédito pendientes de pago.';
            }
            resumenMonto.textContent = '';
            return;
        }

        const totalUsd = creditos.reduce((acc, c) => acc + Number(c.saldo_pendiente), 0);
        const totalCop = Math.ceil(totalUsd * tasaActual);
        const texto = creditos.length === 1 ? '1 crédito pendiente' : `${creditos.length} créditos pendientes`;

        resumen.textContent = texto;
        resumenMonto.textContent = `Saldo total: ${totalUsd.toFixed(2)} USD · ${totalCop} COP`;
    }

    function aplicarFiltro(termino: string) {
        const normalizado = termino.trim().toLowerCase();
        if (!normalizado) return todosLosCreditos;

        return todosLosCreditos.filter(c =>
            String(c.nombre ?? '').toLowerCase().includes(normalizado) ||
            String(c.cedula ?? '').includes(normalizado)
        );
    }

    function renderizarTabla(creditos: Credito[], esBusqueda = false) {
        const tbody = document.getElementById('listaCreditos') as HTMLTableSectionElement;
        const thead = document.getElementById('thead') as HTMLTableSectionElement;

        tbody.innerHTML = '';

        if (creditos.length === 0) {
            thead.style.display = 'none';
            noRegistros(
                esBusqueda
                    ? 'No se encontraron créditos con ese criterio de búsqueda'
                    : 'No hay ventas a crédito pendientes'
            );
            actualizarResumen([], esBusqueda);
            return;
        }

        noRegistros('');
        thead.style.display = 'table-header-group';
        actualizarResumen(creditos, esBusqueda);

        creditos.forEach(credito => {
            const fechaFormateada = formatearFecha(credito.fecha);
            const montoCop = Math.ceil(tasaActual * credito.saldo_pendiente);

            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td data-label="Fecha">${fechaFormateada}</td>
                <td data-label="Cliente">
                    <strong>${credito.nombre.toUpperCase()}</strong><br />
                    <span class="monto-cop">C.I. ${credito.cedula}</span>
                </td>
                <td data-label="Saldo pendiente">
                    <span class="monto-usd">${Number(credito.saldo_pendiente).toFixed(2)} USD</span><br />
                    <span class="monto-cop">${montoCop} COP</span>
                </td>
                <td data-label="Estado">
                    <span class="status-badge status-badge--pendiente">${credito.estado.toUpperCase()}</span>
                </td>
            `;

            const tdAcciones = document.createElement('td');
            tdAcciones.classList.add('acciones');

            const btnDetalle = document.createElement('button');
            btnDetalle.type = 'button';
            btnDetalle.classList.add('btn-editar');
            btnDetalle.textContent = 'VER DETALLE';
            btnDetalle.onclick = () => {
                window.location.href = `/creditos/${credito.id_credito}`;
            };
            tdAcciones.appendChild(btnDetalle);

            tr.appendChild(tdAcciones);
            tbody.appendChild(tr);
        });
    }

    document.addEventListener('DOMContentLoaded', async () => {
        const busqueda = document.getElementById('inputBusqueda') as HTMLInputElement;
        const tbody = document.getElementById('listaCreditos') as HTMLTableSectionElement;
        const thead = document.getElementById('thead') as HTMLTableSectionElement;

        busqueda.addEventListener('input', () => {
            const filtrados = aplicarFiltro(busqueda.value);
            const esBusqueda = busqueda.value.trim().length > 0;
            renderizarTabla(filtrados, esBusqueda);
        });

        try {
            const res = await fetch('/api/creditos');
            const creditos: Credito[] = await res.json();

            if (res.status === 202) {
                tbody.innerHTML = '';
                thead.style.display = 'none';
                actualizarResumen([]);
                noRegistros('No hay ventas a crédito pendientes');
                return;
            }

            tasaActual = await cambioUSDaCOP();
            todosLosCreditos = creditos;
            renderizarTabla(creditos);

        } catch (err) {
            console.error('Error al cargar creditos:', err);
            actualizarResumen([]);
        }
    });

</script>
