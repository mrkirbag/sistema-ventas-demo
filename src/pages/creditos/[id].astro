---
import Layout from '../../layouts/Layout.astro';
import { verificarToken } from '@/utils/auth.js';

const usuario = verificarToken(Astro.request);
if (!usuario) {
    return Astro.redirect('/login');
}

const {id} = Astro.params;
---

<Layout>
    <div class="btn-add_container actions-top">
        <a class="btn-add" href="/creditos">Regresar</a>
    </div>

    <header class="page-header credito-header">
        <p class="eyebrow">Detalle de crédito</p>
        <h1>Venta a crédito</h1>
        <p class="page-intro">Consulta el saldo, los productos facturados y el historial de abonos de esta venta.</p>
    </header>

    <main class="credito-page">
        <section class="datos-cliente">
            <article class="detail-card detail-card--wide">
                <span class="detail-label">Cliente</span>
                <strong id="clienteNombre"></strong>
            </article>
            <article class="detail-card">
                <span class="detail-label">C.I.</span>
                <strong id="clienteCedula"></strong>
            </article>
            <article class="detail-card">
                <span class="detail-label">Teléfono</span>
                <strong id="clienteTelefono"></strong>
            </article>
            <article class="detail-card">
                <span class="detail-label">Fecha de compra</span>
                <strong id="fecha"></strong>
            </article>
            <article class="detail-card">
                <span class="detail-label">Tipo de pago</span>
                <strong id="tipoPago"></strong>
            </article>
            <article class="detail-card">
                <span class="detail-label">Estado</span>
                <strong id="estado"></strong>
            </article>
        </section>

        <section class="credito-kpis">
            <article class="kpi-card kpi-card--total">
                <span class="kpi-label">Monto total</span>
                <div class="kpi-values">
                    <strong id="total"></strong>
                    <span>USD</span>
                </div>
                <p class="kpi-cop"><span id="totalCOP"></span> COP</p>
            </article>
            <article class="kpi-card kpi-card--abonado">
                <span class="kpi-label">Saldo abonado</span>
                <div class="kpi-values">
                    <strong id="abonado">0.00</strong>
                    <span>USD</span>
                </div>
                <p class="kpi-cop"><span id="abonadoCOP">0</span> COP</p>
            </article>
            <article class="kpi-card kpi-card--pendiente">
                <span class="kpi-label">Saldo pendiente</span>
                <div class="kpi-values">
                    <strong id="pendiente"></strong>
                    <span>USD</span>
                </div>
                <p class="kpi-cop"><span id="pendienteCOP"></span> COP</p>
            </article>
            <article class="kpi-card kpi-card--abonos">
                <span class="kpi-label">Abonos registrados</span>
                <div class="kpi-values">
                    <strong id="nroAbonos">0</strong>
                </div>
                <p class="kpi-cop">Pagos parciales realizados</p>
            </article>
        </section>

        <section class="progress-card">
            <div class="progress-heading">
                <span class="detail-label">Progreso de pago</span>
                <strong id="progressLabel">0%</strong>
            </div>
            <div class="progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" id="progressTrack">
                <div class="progress-bar" id="progressBar"></div>
            </div>
        </section>

        <section class="invoice-table-card">
            <div class="table-heading">
                <div>
                    <p class="eyebrow">Productos</p>
                    <h2>Detalle facturado</h2>
                </div>
                <p class="table-caption">Valores expresados en USD y referencia en COP.</p>
            </div>

            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Producto</th>
                            <th>Cantidad</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody id="listaProductos"></tbody>
                </table>
            </div>
        </section>

        <section class="abonos-section">
            <div class="table-heading">
                <div>
                    <p class="eyebrow">Historial</p>
                    <h2>Abonos realizados</h2>
                </div>
                <div class="btn-add_container">
                    <a class="btn-add" href={`/creditos/agregarAbonos/${id}`}>Agregar abono</a>
                </div>
            </div>

            <div class="table-wrap">
                <table>
                    <thead id="abonosThead">
                        <tr>
                            <th>Fecha</th>
                            <th>Monto del abono</th>
                        </tr>
                    </thead>
                    <tbody id="listaAbonos"></tbody>
                </table>
            </div>
        </section>
    </main>

    <div id="mensaje"></div>
    <div id="overlay" class="overlay oculto">
        <div id="modal" class="modal"></div>
    </div>
</Layout>

<style>
    .credito-page {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .actions-top {
        position: relative;
        z-index: 1;
    }

    .credito-header {
        max-width: 58ch;
    }

    .detail-card,
    .invoice-table-card,
    .abonos-section,
    .progress-card {
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(31, 10, 82, 0.08);
        box-shadow: 0 18px 32px rgba(15, 5, 41, 0.08);
    }

    .detail-label,
    .table-caption,
    .kpi-label {
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .datos-cliente {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 0.95rem;
        padding: 0.55rem;
    }

    .detail-card {
        grid-column: span 3;
        display: grid;
        gap: 0.38rem;
        padding: 1rem 1.05rem;
    }

    .detail-card--wide {
        grid-column: span 4;
    }

    .detail-label {
        color: #4f3d78;
    }

    .detail-card strong {
        color: #1d1430;
        font-size: 1rem;
        word-break: break-word;
    }

    .credito-kpis {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .kpi-card {
        display: grid;
        gap: 0.45rem;
        padding: 1rem 1.05rem;
        border-radius: 20px;
        border: 1px solid rgba(31, 10, 82, 0.08);
        box-shadow: 0 14px 26px rgba(15, 5, 41, 0.06);
    }

    .kpi-card--total {
        background: linear-gradient(135deg, rgba(219, 234, 254, 0.9), rgba(191, 219, 254, 0.72));
        border-color: rgba(37, 99, 235, 0.16);
    }

    .kpi-card--abonado {
        background: linear-gradient(135deg, rgba(209, 250, 229, 0.9), rgba(167, 243, 208, 0.72));
        border-color: rgba(5, 150, 105, 0.16);
    }

    .kpi-card--pendiente {
        background: linear-gradient(135deg, rgba(254, 243, 199, 0.92), rgba(253, 230, 138, 0.72));
        border-color: rgba(217, 119, 6, 0.18);
    }

    .kpi-card--abonos {
        background: linear-gradient(135deg, rgba(237, 233, 254, 0.92), rgba(221, 214, 254, 0.72));
        border-color: rgba(109, 40, 217, 0.16);
    }

    .kpi-label {
        color: #4f3d78;
    }

    .kpi-values {
        display: flex;
        align-items: baseline;
        gap: 0.35rem;
    }

    .kpi-values strong {
        font-size: 1.35rem;
        line-height: 1;
        color: var(--primary-strong);
    }

    .kpi-values span {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
    }

    .kpi-cop {
        margin: 0;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
    }

    .progress-card {
        padding: 1rem 1.1rem;
    }

    .progress-heading {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
    }

    .progress-heading strong {
        font-size: 1rem;
        color: var(--primary-strong);
    }

    .progress-track {
        height: 12px;
        border-radius: 999px;
        background: rgba(31, 10, 82, 0.08);
        overflow: hidden;
    }

    .progress-bar {
        height: 100%;
        width: 0%;
        border-radius: inherit;
        background: linear-gradient(90deg, #059669, #34d399);
        transition: width 420ms ease;
    }

    .invoice-table-card,
    .abonos-section {
        padding: 1.15rem;
    }

    .table-heading {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .table-heading h2 {
        font-size: 1.2rem;
    }

    .table-caption {
        color: #4f3d78;
        text-align: right;
        max-width: 28ch;
    }

    :global(.monto-usd) {
        font-weight: 700;
        color: var(--primary-strong);
    }

    :global(.monto-cop) {
        font-size: 0.78rem;
        color: var(--text-muted);
    }

    @media (max-width: 1024px) {
        .credito-kpis {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 768px) {
        .datos-cliente,
        .credito-kpis {
            grid-template-columns: 1fr;
        }

        .detail-card,
        .detail-card--wide {
            grid-column: auto;
        }

        .table-heading {
            flex-direction: column;
        }

        .table-caption {
            text-align: left;
            max-width: none;
        }
    }
</style>

<script>

    import { noRegistros } from "@/utils/helpers/mensajes.js";
    import { formatearFecha } from "@/utils/helpers/formateoFecha.js";
    import { cambioUSDaCOP } from "@/utils/helpers/cambioMoneda.js";

    interface Producto {
        codigo_producto: string;
        nombre_producto: string;
        cantidad: number;
        subtotal: number;
    }

    interface Abono {
        id_abono: number;
        fecha: string;
        monto: number;
    }

    function actualizarProgreso(total: number, abonado: number) {
        const porcentaje = total > 0 ? Math.min(100, Math.round((abonado / total) * 100)) : 0;
        const progressBar = document.getElementById('progressBar') as HTMLDivElement;
        const progressLabel = document.getElementById('progressLabel') as HTMLElement;
        const progressTrack = document.getElementById('progressTrack') as HTMLDivElement;

        if (progressBar) progressBar.style.width = `${porcentaje}%`;
        if (progressLabel) progressLabel.textContent = `${porcentaje}%`;
        if (progressTrack) progressTrack.setAttribute('aria-valuenow', porcentaje.toString());
    }

    document.addEventListener('DOMContentLoaded', rellenarCampos);

    const id = location.pathname.split("/").pop();

    async function rellenarCampos() {
        try {
            const response = await fetch(`/api/creditos/${id}`);
            if (!response.ok) throw new Error("Error al obtener crédito");
            const data = await response.json();

            (document.querySelector('#clienteNombre') as HTMLElement).textContent = data.cliente.nombre.toUpperCase();
            (document.querySelector('#clienteCedula') as HTMLElement).textContent = data.cliente.cedula;
            (document.querySelector('#clienteTelefono') as HTMLElement).textContent = data.cliente.telefono;

            const fechaFormateada = formatearFecha(data.venta.fecha);
            (document.querySelector('#fecha') as HTMLElement).textContent = fechaFormateada;
            (document.querySelector('#tipoPago') as HTMLElement).textContent = data.venta.tipo_pago.toUpperCase();
            (document.querySelector('#estado') as HTMLElement).textContent = data.venta.estado.toUpperCase();

            const tasa = await cambioUSDaCOP();
            const montoTotal = Number(data.venta.monto_total);

            (document.querySelector('#total') as HTMLElement).textContent = montoTotal.toFixed(2);
            (document.querySelector('#totalCOP') as HTMLElement).textContent = Math.ceil(tasa * montoTotal).toString();

            const saldoPendiente = Number(data.credito.saldo_pendiente);
            (document.querySelector('#pendiente') as HTMLElement).textContent = saldoPendiente.toFixed(2);
            (document.querySelector('#pendienteCOP') as HTMLElement).textContent = Math.ceil(tasa * saldoPendiente).toString();

            const dataProductos: Producto[] = data.productos;
            const tbody = document.querySelector('#listaProductos') as HTMLTableSectionElement;
            dataProductos.forEach(p => {
                const tr = document.createElement('tr');
                const subtotalPesos = Math.ceil(tasa * p.subtotal);
                tr.innerHTML = `
                    <td data-label="Código">${p.codigo_producto.toUpperCase()}</td>
                    <td data-label="Producto">${p.nombre_producto.toUpperCase()}</td>
                    <td data-label="Cantidad">${p.cantidad}</td>
                    <td data-label="Subtotal">
                        <span class="monto-usd">${p.subtotal.toFixed(2)} USD</span><br />
                        <span class="monto-cop">${subtotalPesos} COP</span>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            const totalAbonadoText = document.querySelector('#abonado') as HTMLElement;
            const totalAbonadoCopText = document.querySelector('#abonadoCOP') as HTMLElement;
            const listaAbonosTbody = document.querySelector('#listaAbonos') as HTMLTableSectionElement;
            const abonosThead = document.querySelector('#abonosThead') as HTMLTableSectionElement;
            const nroAbonos = document.querySelector('#nroAbonos') as HTMLElement;

            const resAbonos = await fetch(`/api/abonos/${id}`);
            const dataAbonos: Abono[] = await resAbonos.json();

            let totalAbonadoUsd = 0;

            if (resAbonos.status === 202) {
                listaAbonosTbody.innerHTML = '';
                abonosThead.style.display = 'none';
                noRegistros('No se han registrado abonos para esta venta a crédito');
            } else {
                noRegistros('');
                abonosThead.style.display = 'table-header-group';

                dataAbonos.forEach(abono => {
                    totalAbonadoUsd += abono.monto;
                    const fechaAbono = formatearFecha(abono.fecha);
                    const montoCop = Math.ceil(tasa * abono.monto);

                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td data-label="Fecha">${fechaAbono}</td>
                        <td data-label="Monto">
                            <span class="monto-usd">${abono.monto.toFixed(2)} USD</span><br />
                            <span class="monto-cop">${montoCop} COP</span>
                        </td>
                    `;
                    listaAbonosTbody.appendChild(tr);
                });
            }

            totalAbonadoText.textContent = totalAbonadoUsd.toFixed(2);
            totalAbonadoCopText.textContent = Math.ceil(totalAbonadoUsd * tasa).toString();
            nroAbonos.textContent = resAbonos.status === 202 ? '0' : dataAbonos.length.toString();
            actualizarProgreso(montoTotal, totalAbonadoUsd);

        } catch (error) {
            console.error('Error al cargar crédito:', error);
        }
    }

</script>
