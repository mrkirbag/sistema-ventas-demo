---
import Layout from '../../../layouts/Layout.astro';
import { verificarToken } from '@/utils/auth.js';

const usuario = verificarToken(Astro.request);
if (!usuario) {
    return Astro.redirect('/login');
}

const {id} = Astro.params;
const fechaVenezuela = new Intl.DateTimeFormat('es-VE', {
        timeZone: 'America/Caracas',
        year: 'numeric',
        month: '2-digit',
        day: '2-digit'
    }).format(new Date());

const [dia, mes, ano] = fechaVenezuela.split('/');
const fechaCompleta = `${ano}-${mes}-${dia}`;
---

<Layout>
    <header class="page-header">
        <p class="eyebrow">Cuentas por cobrar</p>
        <h1>Registrar abono</h1>
        <p class="page-intro">Ingresa el monto y la fecha del pago parcial para actualizar el saldo pendiente del crédito.</p>
    </header>

    <div class="btn-add_container">
        <a class="btn-add" href={`/creditos/${id}`}>Regresar</a>
    </div>

    <section class="abono-summary-card" aria-live="polite">
        <div class="summary-icon" aria-hidden="true">$</div>
        <div>
            <p class="summary-eyebrow">Saldo pendiente</p>
            <p class="summary-amount">
                <span id="pendiente">—</span> <small>USD</small>
            </p>
            <p class="summary-subtext"><span id="pendienteCOP">—</span> COP</p>
        </div>
    </section>

    <section class="form-container page-form abono-form">
        <form id="formulario">
            <div class="form-field">
                <label for="fecha">Fecha del abono</label>
                <input type="date" name="fecha" id="fecha" value={fechaCompleta} />
            </div>

            <div class="form-field">
                <label for="montoAbono">Monto en USD</label>
                <input
                    type="text"
                    name="montoAbono"
                    id="montoAbono"
                    placeholder="Ej. 25.50"
                    inputmode="decimal"
                />
                <p class="field-hint" id="montoCopPreview">El equivalente en COP se mostrará al ingresar el monto.</p>
            </div>

            <div class="form-actions">
                <button type="submit">Registrar abono</button>
            </div>
        </form>
    </section>

    <div id="mensaje"></div>
    <div id="overlay" class="overlay oculto">
        <div id="modal" class="modal"></div>
    </div>
</Layout>

<style>
    .abono-summary-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.15rem;
        border-radius: var(--radius-lg);
        background: linear-gradient(135deg, rgba(254, 243, 199, 0.55), rgba(253, 230, 138, 0.35));
        border: 1px solid rgba(217, 119, 6, 0.18);
        box-shadow: var(--shadow-card);
        max-width: 480px;
    }

    .summary-icon {
        display: grid;
        place-items: center;
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: linear-gradient(135deg, #b45309, #d97706);
        color: #fff;
        font-family: "Archivo Black", sans-serif;
        font-size: 1.35rem;
        flex-shrink: 0;
        box-shadow: 0 10px 22px rgba(180, 83, 9, 0.25);
    }

    .summary-eyebrow {
        margin: 0 0 0.2rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #92400e;
    }

    .summary-amount {
        margin: 0;
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--primary-strong);
        line-height: 1.1;
    }

    .summary-amount small {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--text-muted);
    }

    .summary-subtext {
        margin: 0.3rem 0 0;
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-muted);
    }

    .abono-form {
        max-width: 520px;
        margin-left: 0;
    }

    .field-hint {
        margin: 0;
        font-size: 0.82rem;
        color: var(--text-muted);
        font-weight: 500;
    }

    @media (max-width: 768px) {
        .abono-summary-card {
            max-width: none;
        }
    }
</style>

<script>

    import { mostrarError, mostrarMensaje, confirmarAccion } from '@/utils/helpers/mensajes.js';
    import { cambioUSDaCOP } from '@/utils/helpers/cambioMoneda.js';

    const id = location.pathname.split("/").pop() as string;
    const saldoPendiente = document.querySelector('#pendiente') as HTMLElement;
    const saldoPendienteCOP = document.querySelector('#pendienteCOP') as HTMLElement;
    const montoCopPreview = document.querySelector('#montoCopPreview') as HTMLParagraphElement;
    const montoAbonoInput = document.querySelector('#montoAbono') as HTMLInputElement;

    let tasaActual = 0;
    let saldoMaximo = 0;

    document.addEventListener('DOMContentLoaded', async () => {
        try {
            const response = await fetch(`/api/creditos/${id}`);
            const data = await response.json();

            saldoMaximo = Number(data.credito.saldo_pendiente);
            const saldo = saldoMaximo.toFixed(2);
            saldoPendiente.textContent = saldo;

            tasaActual = await cambioUSDaCOP();
            saldoPendienteCOP.textContent = Math.ceil(tasaActual * saldoMaximo).toString();

        } catch (error) {
            console.error('Error al cargar datos de crédito o tasa:', error);
            saldoPendiente.textContent = '—';
            saldoPendienteCOP.textContent = '—';
        }
    });

    montoAbonoInput.addEventListener('input', () => {
        const raw = montoAbonoInput.value.trim().replace(',', '.');
        const monto = parseFloat(raw);

        if (!montoAbonoInput.value || isNaN(monto) || monto <= 0) {
            montoCopPreview.textContent = 'El equivalente en COP se mostrará al ingresar el monto.';
            return;
        }

        const cop = Math.ceil(monto * tasaActual);
        montoCopPreview.textContent = `Equivalente aproximado: ${cop} COP`;
    });

    const formulario = document.getElementById('formulario') as HTMLFormElement;

    formulario.addEventListener('submit', async (event: Event) => {
        event.preventDefault();

        const fechaInput = document.querySelector('#fecha') as HTMLInputElement;
        const raw = montoAbonoInput.value.trim().replace(',', '.');
        const montoAbono = parseFloat(raw);
        const fecha = fechaInput.value?.trim();

        if (!montoAbonoInput.value || isNaN(montoAbono) || montoAbono <= 0) {
            mostrarError('Debe ingresar un monto válido mayor a cero');
            return;
        }

        if (montoAbono > saldoMaximo) {
            mostrarError(`El abono no puede superar el saldo pendiente (${saldoMaximo.toFixed(2)} USD)`);
            return;
        }

        if (!fecha) {
            mostrarError('Debe seleccionar una fecha válida');
            return;
        }

        const fechaValida = /^\d{4}-\d{2}-\d{2}$/.test(fecha);
        if (!fechaValida) {
            mostrarError('El formato de fecha no es válido');
            return;
        }

        const hoy = new Date().toISOString().split('T')[0];
        if (fecha > hoy) {
            mostrarError('La fecha no puede ser futura');
            return;
        }

        const confirmar = await confirmarAccion(`¿Deseas registrar un abono por ${montoAbono.toFixed(2)} USD?`, {
            titulo: 'Registrar abono',
            textoAceptar: 'Registrar',
        });
        if (!confirmar) return;

        const response = await fetch("/api/abonos/agregarAbono", {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ id, fecha, montoAbono }),
        });

        if (!response.ok) {
            const mensaje = await response.text();
            switch (response.status) {
                case 400:
                    mostrarError('Datos inválidos: ' + mensaje);
                    break;
                case 404:
                    mostrarError('Crédito no encontrado');
                    break;
                case 409:
                    mostrarError(mensaje);
                    break;
                case 500:
                    mostrarError('Error interno del servidor');
                    break;
                default:
                    mostrarError('Error inesperado: ' + response.status);
            }
            return;
        }

        const data = await response.json();
        mostrarMensaje(data.message);

        if (data.venta_actualizada) {
            mostrarMensaje('La venta fue completada con este abono');
            return setTimeout(() => {
                window.location.href = `/creditos/`;
            }, 2000);
        }

        setTimeout(() => {
            window.location.href = `/creditos/${id}`;
        }, 1000);
    });
</script>
