---
import Layout from '../../layouts/Layout.astro';
import { verificarToken } from '@/utils/auth.js';

const usuario = verificarToken(Astro.request);
if (!usuario) {
    return Astro.redirect('/login');
}
if (usuario.rol !== 'admin') {
    return Astro.redirect('/'); 
}
---

<Layout>
    <header class="page-header">
        <p class="eyebrow">Administración</p>
        <h1>Agregar usuario</h1>
        <p class="page-intro">Crea una cuenta con nombre, usuario, rol y contraseña segura.</p>
    </header>

    <div class="btn-add_container">
        <a class="btn-add" href="/usuarios">Regresar</a>
    </div>

    <section class="form-container page-form">
        <form id="formulario" autocomplete="off">
            <div class="form-field">
                <label for="nombre">Nombre y apellido</label>
                <input
                    type="text"
                    name="nombre"
                    id="nombre"
                    placeholder="Ej. María González"
                    autocomplete="off"
                    autocorrect="off"
                    autocapitalize="none"
                    spellcheck="false"
                />
            </div>

            <div class="form-field">
                <label for="usuario">Usuario</label>
                <input
                    type="text"
                    name="usuario"
                    id="usuario"
                    placeholder="Ej. mgonzalez"
                    autocomplete="off"
                    autocorrect="off"
                    autocapitalize="none"
                    spellcheck="false"
                />
            </div>

            <div class="form-field">
                <label for="rol">Rol</label>
                <select name="rol" id="rol">
                    <option value="" disabled selected>Seleccionar rol</option>
                    <option value="admin">Administrador</option>
                    <option value="empleado">Empleado</option>
                </select>
            </div>

            <div class="form-field">
                <label for="contrasena">Contraseña</label>
                <div class="password-container">
                    <input
                        type="password"
                        name="contrasena"
                        id="contrasena"
                        placeholder="Mínimo 6 caracteres"
                        autocomplete="off"
                        autocorrect="off"
                        autocapitalize="none"
                        spellcheck="false"
                    />
                    <button type="button" class="toggle-password" data-target="contrasena">Mostrar</button>
                </div>
            </div>

            <div class="form-field">
                <label for="contrasena2">Confirmar contraseña</label>
                <div class="password-container">
                    <input
                        type="password"
                        name="contrasena2"
                        id="contrasena2"
                        placeholder="Repite la contraseña"
                        autocomplete="off"
                        autocorrect="off"
                        autocapitalize="none"
                        spellcheck="false"
                    />
                    <button type="button" class="toggle-password" data-target="contrasena2">Mostrar</button>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit">Agregar usuario</button>
            </div>
        </form>
    </section>

    <div id="mensaje"></div>
    <div id="overlay" class="overlay oculto"> 
        <div id="modal" class="modal"></div>
    </div>
</Layout>

<script>

    import { mostrarError, mostrarMensaje } from '@/utils/helpers/mensajes.js';

    function togglePassword(button: HTMLButtonElement): void {
        const inputId = button.dataset.target;
        if (!inputId) return;

        const input = document.getElementById(inputId) as HTMLInputElement | null;
        if (!input) return;

        const visible = input.type === 'text';
        input.type = visible ? 'password' : 'text';
        button.textContent = visible ? 'Mostrar' : 'Ocultar';
    }

    document.querySelectorAll('.toggle-password').forEach((button) => {
        button.addEventListener('click', () => {
            togglePassword(button as HTMLButtonElement);
        });
    });

    const formulario = document.getElementById('formulario') as HTMLFormElement;

    formulario.addEventListener('submit', async (event) => { 
        
        event.preventDefault();
        
        const nombre = (document.getElementById('nombre') as HTMLInputElement).value.trim();
        const usuario = (document.getElementById('usuario') as HTMLInputElement).value.trim();
        const contrasena = (document.getElementById('contrasena') as HTMLInputElement).value;
        const contrasena2 = (document.getElementById('contrasena2') as HTMLInputElement).value;
        const rol = (document.getElementById('rol') as HTMLSelectElement).value;

        if (nombre === '' || usuario === '' || contrasena === '' || contrasena2 === '' || rol === '') {
            mostrarError('Todos los campos son obligatorios.'); 
            return;
        }

        if (contrasena !== contrasena2) {
            mostrarError('Las contraseñas no coinciden');
            return;
        }

        try {
            const response = await fetch("/api/usuarios/registrar", {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ nombre, usuario, contrasena, rol })
            });

            if (!response.ok) {
                throw new Error('Error al agregar usuario: ' + response.status);
            }

            mostrarMensaje('Usuario agregado exitosamente.');
            setTimeout(() => {
                window.location.href = '/usuarios';
            }, 1000);

        } catch (error) {
            console.error(error);
            mostrarError('No se pudo agregar el usuario. Inténtalo de nuevo.');
        }
    });

</script>
