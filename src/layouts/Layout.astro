---
import Navbar from "../components/Navbar.astro"
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="shortcut icon" href="/favicon.webp" type="image/webp">
		<meta name="generator" content={Astro.generator} />
		<title>Sistema Inventario</title>
	</head>
	<body>

		<div class="navbar">
			<Navbar />
		</div>

		<div class="content">
			<slot />
		</div>

		<script is:inline>
			(() => {
				const disableSuggestions = () => {
					document.querySelectorAll('form').forEach((form) => {
						form.setAttribute('autocomplete', 'off');
					});

					document.querySelectorAll('input, textarea').forEach((field) => {
						field.setAttribute('autocomplete', 'off');
						field.setAttribute('autocorrect', 'off');
						field.setAttribute('autocapitalize', 'none');
						field.setAttribute('spellcheck', 'false');
					});
				};

				disableSuggestions();
				document.addEventListener('astro:page-load', disableSuggestions);
			})();
		</script>
	</body>
</html>

<style is:global>

	*, *::before, *::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	:root {
		--primary-color: #0F0529;
		--secondary-color: #1F0A52;
		--gray-color: #cccccc;
		--table-header-color: #DADADA;
		--danger-color: #ff4d4d;
		--danger-hover-color: #a51515;
		--success-color: #008000;
		--success-hover-color: #006600;
	}

	@font-face {
		font-family: 'Archivo Black';
		src: url('/fonts/ArchivoBlack-Regular.woff2') format('woff2');
		font-weight: normal;
		font-style: normal;
	}

	@font-face {
		font-family: 'Roboto';
		src: url('/fonts/Roboto-Regular.woff2') format('woff2');
		font-weight: normal;
		font-style: normal;	
	}

	body {
		font-family: 'Roboto', sans-serif;
	}

	.navbar {
		position: fixed;
		z-index: 1;
	}

	.content {
		max-width: 100%;
		height: 100%;
		min-height: 100vh;
		margin: 0 auto;
		margin-left: 180px;
		padding: 1rem 2rem;
		background-color: #fff;
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	h1 {
		text-align: center;
		font-size: 2rem;
		margin: 1rem 0;
		font-family: 'Archivo Black', sans-serif;
	}

	.btn-add_container {
		background: var(--primary-color);
		border-radius: 5px;
		max-width: 150px;
		display: flex;
		justify-content: center;
		align-items: center;

		& .btn-add {
			padding: .35rem .75rem;
			width: 100%;
			text-align: center;
			color: #fff;
			text-decoration: none;
			font-size: .9rem;
		}

		&:hover {
			background: var(--secondary-color);
			scale: 1.05;
			cursor: pointer;
		}

		&:active {
			scale: 0.95;
			cursor: pointer;
		}	

	}

	.input-busqueda_container {
		display: flex;
		justify-content: center;
		margin-bottom: 2rem;

		& input {
			width: 100%;
			max-width: 400px;
			padding: .5rem;
			border: 1px solid var(--gray-color);
			border-radius: 7px;
			font-size: .9rem;

			&:focus {
				outline: none;
				border: 1.5px solid var(--primary-color);
			}
		}
	}

	table {
		width: 100%;
		margin-bottom: .5rem;

		& th {
			background-color: var(--table-header-color);
			font-weight: bold;
			padding: 1rem;
			text-align: left;
		}

		tr {
			border-bottom: 1px solid var(--gray-color);
			width: 100%;

			&:last-child {
				border-bottom: none;
			}
			&:hover {
				background-color: var(--table-header-color);
			}
		}

		td {
			padding: .75rem;
			text-align: left;
			font-size: .85rem;
		}

		.acciones {
			display: flex;
			gap: 10px;

			& button {
				font-size: .7rem;
				color: #fff;
				font-weight: 700;
				border: none;
				padding: .25rem .5rem;
				border-radius: 5px;

				&:hover {
					cursor: pointer;
				}
			}

			& .btn-clave, .btn-stock, .btn-detalles {
				background: var(--primary-color);

				&:hover {
					background-color: var(--secondary-color);
				}
			}

			& .btn-eliminar {
				background-color: var(--danger-color);

				&:hover {
					background-color: var(--danger-hover-color);
				}
			}

			& .btn-editar {
				background-color: var(--primary-color);

				&:hover {
					background-color: var(--secondary-color);
				}
			}

			
		}
	}
	
	.btn-vermas_container {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 20px;

		& button {
			background-color: var(--primary-color);
			color: #fff;
			border-radius: 5px;
			max-width: 150px;
			padding: .35rem .75rem;
			text-align: center;
			font-size: .9rem;
			border: none;
			outline: none;

			&:hover {
				background-color: var(--secondary-color);
				cursor: pointer;
				scale: 1.05;
			}

			&:active {
				scale: 0.95;
				cursor: pointer;
			}
		}
	}

	.form-container {
		margin: 0 auto;
		width: 400px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
	}

		form {
		width: 400px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 1rem;
	}

	form div {
		width: 100%;
	}

	form label {
		font-size: .75rem;
		font-weight: 700;
	}

	form input, form select {
		width: 100%;
		max-width: 400px;
		padding: .5rem;
		border: 1px solid var(--gray-color);
		border-radius: 7px;
		font-size: .9rem;

		&:focus {
			border: 1.5px solid var(--primary-color);
		}
	}

	select {
		appearance: none;
		-moz-appearance: none;
		-webkit-appearance: none;
		background: url('/down-arrow.svg') no-repeat right 10px center;
	}

	form select option {
		font-size: .8rem;
		background: var(--gray-color);
	}

	form button, .button {
		text-decoration: none;
		margin-top: 1rem;
		background-color: var(--primary-color);
		color: #fff;
		border-radius: 5px;
		max-width: 150px;
		padding: .35rem .75rem;
		text-align: center;
		font-size: .9rem;
		border: none;
		outline: none;

		&:hover{
			background-color: var(--secondary-color);
			cursor: pointer;
			scale: 1.05;
		}

		&:active {
			scale: 0.95;
			cursor: pointer;
		}
	}

	.password-container {
		width: 100%;
        display: flex;
        gap: 10px;

        & span {
            cursor: pointer;
            font-size: 1.25rem;
            border: .5px solid var(--gray-color);
            border-radius: 5px;
            background: var(--primary-color);
        }
    }

	.mensaje-sin-registros {
		margin: 0 auto;
		width: 100%;
		color: #fff;
		background: var(--danger-color);
		text-align: center;
		font-size: 1.2rem;
		padding: .5rem 1rem;
	}

	@media (max-width: 768px) {

		h1 {
			text-align: left;
			font-size: 1.5rem;
		}
		table, tbody, th, td, tr {
			display: block;
			width: 100%;
		}

		thead {
			display: none !important
		}

		tr {
			margin-bottom: 0.5rem;
			border: 1px solid var(--gray-color);
			border-radius: 6px;
			padding: .75rem;
			background-color: var(--gray-color);
		}

		td {
			text-align: left;
			padding: .2rem;
			position: relative;
			font-size: .85rem;
		}

		td::before {
			content: attr(data-label);
			font-weight: bold;
			display: block;
			margin-bottom: .1rem;
			color: var(--primary-color);
		}

		form {
			max-width: 300px;
		}
	}

	@media (max-width: 768px) {
		.content {
			margin-left: 0;
			padding: 1rem 1rem;
		}

		.navbar {
			z-index: 1000;
		}

		.form-container {
			width: 100%;
		}
	}

	.modal {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: clamp(200px, 80vw, 400px); 
        max-height: 80vh;
        background: #FFF;
        color: #000;
        font-size: 1.2rem;
        font-family: "Roboto", sans-serif; 
        padding: 1.5rem;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2); 
        display: flex;
        flex-direction: column; 
        align-items: center;
        justify-content: center;
		text-align: center;
        z-index: 1000;
        transition: display 3s ease-in-out;
    }

    .overlay {
        position: fixed;
        top: 0; 
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        z-index: 999;
        transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
    }

    .visible {
        opacity: 1;
        display: flex;
        pointer-events: auto;
    }

    .oculto {
        opacity: 0;
        display: none;
        pointer-events: none;
    }

    .mensaje-exito {
        border: 6px solid var(--success-color);
    }

    .mensaje-error {
        border: 6px solid var(--danger-color);
    }

</style>
