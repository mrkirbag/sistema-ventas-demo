---
import empresa from '../data/empresa.json';
---

<section class="empresa">
    <img src={empresa.logo} alt={`Logo de ${empresa.nombre}`} />
    <div>
        <p class="eyebrow">{empresa.etiquetaMarca}</p>
        <h2 class="title">{empresa.nombre}</h2>
        <h3>{empresa.rif} / {empresa.telefono}</h3>
        {empresa.subtitulo && <p class="subtitulo">{empresa.subtitulo}</p>}
    </div>
</section>

<style>
    .empresa {
        grid-column: 1 / 2;
        grid-row: 2 / 3;
        padding: 1.5rem;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(237, 231, 248, 0.88));
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .empresa img {
        max-width: 140px;
        height: auto;
    }

    .empresa div {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .eyebrow {
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--secondary-color);
    }

    .title {
        font-family: 'Archivo Black', sans-serif;
        font-size: 1.7rem;
        text-align: center;
        color: var(--secondary-color);
        margin: 0;
    }

    h3 {
        color: var(--secondary-color);
        font-weight: 700;
        font-size: 1.25rem;
        margin: 0;
    }

    .subtitulo {
        color: var(--secondary-color);
        font-size: 0.9rem;
        max-width: 32ch;
        margin: 0;
    }
</style>
